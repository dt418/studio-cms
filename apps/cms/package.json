{
  "name": "studio-cms-cms",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "studiocms": "studiocms",
    "migrate": "studiocms migrate",
    "dev": "astro dev --port 4322",
    "build": "astro build",
    "preview": "astro preview --port 4322",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\" --config ../../eslint.config.js",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,astro}\" --config ../../eslint.config.js --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json,md}\" \"*.{js,mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json,md}\" \"*.{js,mjs,json}\"",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/internal-helpers": "0.7.5",
    "@astrojs/node": "^9.5.5",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.79",
    "@libsql/client": "^0.15.15",
    "@studiocms/blog": "^0.3.0",
    "@studiocms/cfetch": "^0.5.1",
    "@studiocms/html": "^0.3.0",
    "@studiocms/markdoc": "^0.3.0",
    "@studiocms/md": "^0.3.0",
    "@studiocms/mdx": "^0.3.0",
    "@studiocms/ui": "^1.2.0",
    "@studiocms/wysiwyg": "^0.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.18.1",
    "canvas": "3.2.3",
    "effect": "^3.21.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "studiocms": "^0.4.4",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3"
  }
}
