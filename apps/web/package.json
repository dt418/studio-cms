{
  "name": "@danhthanh/web",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "og:generate": "node scripts/generate-og-image.mjs",
    "build": "node scripts/generate-og-image.mjs && astro build && node scripts/generate-search-index.mjs && pagefind --site dist",
    "preview": "astro preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\" --config ../../eslint.config.js",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,astro}\" --config ../../eslint.config.js --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json,md}\"",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/figtree": "^5.2.10",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.18.1",
    "astro-expressive-code": "^0.41.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expressive-code-twoslash": "^0.6.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "pagefind": "^1.5.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
