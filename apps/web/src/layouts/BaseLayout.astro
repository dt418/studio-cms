---
import '../styles/app.css'
import { SITE } from '@/lib/site'

export interface Props {
  title: string
  description?: string
  image?: string
  canonicalUrl?: string
  publishedTime?: string
  modifiedTime?: string
  author?: string
  type?: 'website' | 'article'
  noindex?: boolean
  jsonLd?: Record<string, unknown>
}

const {
  title,
  description = SITE.description,
  image,
  canonicalUrl,
  publishedTime,
  modifiedTime,
  author = SITE.author,
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props

const siteUrl = (Astro.site ?? Astro.url).origin || 'http://localhost:4321'
const defaultImage = `${siteUrl}/og-image.png`
const ogImageUrl = image ?? defaultImage
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      try {
        const config = JSON.parse(localStorage.getItem('theme-config') ?? 'null')
        const root = document.documentElement

        if (config?.theme === 'light') {
          root.classList.remove('dark')
        } else {
          root.classList.add('dark')
        }

        if (config?.primary && typeof config.primary === 'object') {
          const { l, c, h } = config.primary
          if (typeof l === 'number' && typeof c === 'number' && typeof h === 'number') {
            root.style.setProperty('--primary', `oklch(${l} ${c} ${h})`)
          }
        }
      } catch {
        document.documentElement.classList.add('dark')
      }
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="en_US" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Author -->
    {author && <meta name="author" content={author} />}

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-foreground flex min-h-screen flex-col antialiased">
    <!-- Header (CPZ style, DT branding kept) -->
    <header class="border-border bg-background/80 sticky top-0 z-50 border-b backdrop-blur-xl">
      <div class="container flex h-14 items-center">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="text-lg">DT</span>
        </a>
        <nav
          class="ml-auto flex items-center gap-4 font-mono text-[0.62rem] tracking-[0.24em] uppercase"
        >
          <a href="/blog" class="text-muted-foreground hover:text-foreground transition-colors">
            writing
          </a>
          <a href="/rss.xml" class="text-muted-foreground hover:text-foreground transition-colors">
            rss
          </a>
        </nav>
      </div>
    </header>
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-border border-t font-mono text-[0.62rem] tracking-[0.24em] uppercase">
      <div class="container py-16">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
          <div>
            <h2 class="mb-4 text-2xl font-bold tracking-tight">
              Building onboarding, internal tooling, and operational systems with clear proof.
            </h2>
            <p class="text-muted-foreground max-w-lg text-sm leading-relaxed">
              Software engineer building systems that make complex products easier to adopt and
              trust.
            </p>
          </div>
          <div class="lg:flex lg:flex-col lg:items-end lg:text-right">
            <h3
              class="text-muted-foreground/60 mb-4 text-xs font-semibold tracking-wider uppercase"
            >
              links
            </h3>
            <ul class="space-y-3">
              <li>
                <a
                  href={`mailto:${SITE.email}`}
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  email →
                </a>
              </li>
              <li>
                <a
                  href={SITE.social.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  github →
                </a>
              </li>
              <li>
                <a
                  href="/rss.xml"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  rss →
                </a>
              </li>
              <li>
                <a
                  href={SITE.social.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  linkedin →
                </a>
              </li>
            </ul>
          </div>
        </div>
        <div class="border-border text-muted-foreground/50 mt-16 border-t pt-6">
          <p>{SITE.name} / {new Date().getFullYear()}</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    )

    document.querySelectorAll('.animate-on-scroll').forEach((el) => {
      observer.observe(el)
    })
  })
</script>
