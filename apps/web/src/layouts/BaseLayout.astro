---
import '../styles/app.css'
import { Font } from 'astro:assets'
import { SITE } from '@/lib/site'
import { resolveOgImage } from '@/lib/og-image'
import LanguageSwitcher from '@/components/LanguageSwitcher.astro'
import { getTranslations } from '@/lib/i18n'
import type { SupportedLocale } from '@/lib/content-utils'

export interface Props {
  title: string
  description?: string
  image?: string
  canonicalUrl?: string
  publishedTime?: string
  modifiedTime?: string
  author?: string
  type?: 'website' | 'article'
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  lang?: SupportedLocale
  currentPath?: string
  alternateUrls?: Record<SupportedLocale, string>
}

const {
  title,
  description = SITE.description,
  image,
  canonicalUrl,
  publishedTime,
  modifiedTime,
  author = SITE.author,
  type = 'website',
  noindex = false,
  jsonLd,
  lang = 'vi',
  currentPath = Astro.url.pathname,
  alternateUrls,
} = Astro.props

const siteUrl = (Astro.site ?? Astro.url).origin || 'http://localhost:4321'
const defaultImage = `${siteUrl}/og-image.png`
const ogImageUrl = resolveOgImage(image, siteUrl, defaultImage)
const ogImageType = ogImageUrl.endsWith('.webp') ? 'image/webp' : 'image/png'

const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`
const i18n = getTranslations(lang)
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={i18n.rss.title} href="/rss.xml" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-jetbrains-mono" />
    <script is:inline>
      try {
        const config = JSON.parse(localStorage.getItem('theme-config') ?? 'null')
        const root = document.documentElement

        if (config?.theme === 'light') {
          root.classList.remove('dark')
        } else {
          root.classList.add('dark')
        }

        if (config?.primary && typeof config.primary === 'object') {
          const { l, c, h } = config.primary
          if (typeof l === 'number' && typeof c === 'number' && typeof h === 'number') {
            root.style.setProperty('--primary', `oklch(${l} ${c} ${h})`)
          }
        }
      } catch {
        document.documentElement.classList.add('dark')
      }
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonical} />
    {
      alternateUrls &&
        Object.entries(alternateUrls).map(([locale, url]) => (
          <link rel="alternate" hreflang={locale} href={url} />
        ))
    }
    {alternateUrls && <link rel="alternate" hreflang="x-default" href={alternateUrls['vi']} />}

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'vi_VN'} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {author && <meta property="article:author" content={author} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.social.twitter} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {author && <meta name="twitter:creator" content={SITE.social.twitter} />}

    <!-- Author -->
    {author && <meta name="author" content={author} />}

    <!-- JSON-LD Structured Data -->
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="bg-background text-foreground flex min-h-screen flex-col antialiased">
    <a
      href="#main-content"
      class="focus:bg-background focus:ring-ring sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-md focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:shadow-lg focus:ring-2 focus:outline-none"
    >
      {i18n.nav.skipToContent}
    </a>
    <!-- Header (CPZ style, DT branding kept) -->
    <header class="border-border bg-background/80 sticky top-0 z-50 border-b backdrop-blur-xl">
      <div class="container flex h-14 items-center">
        <a
          href={`/${lang}`}
          class="flex items-center gap-2 font-semibold tracking-tight"
          aria-label={i18n.nav.brandHome}
        >
          <span class="text-lg">DT</span>
        </a>
        <nav
          class="ml-auto flex items-center gap-4 font-mono text-[0.62rem] tracking-[0.24em] uppercase"
          aria-label={i18n.nav.primary}
        >
          <a
            href={`/${lang}/blog`}
            class="text-muted-foreground hover:text-foreground transition-colors"
          >
            {i18n.nav.writing}
          </a>
          <a href="/rss.xml" class="text-muted-foreground hover:text-foreground transition-colors">
            {i18n.nav.rss}
          </a>
          <LanguageSwitcher
            currentLang={lang}
            currentPath={currentPath}
            label={i18n.language.navigation}
            languageNames={i18n.language.names}
            getSwitchLabel={i18n.language.switchTo}
          />
        </nav>
      </div>
    </header>
    <main id="main-content" tabindex="-1" class="flex-1">
      <slot />
    </main>
    <footer class="border-border border-t font-sans text-[0.62rem] tracking-[0.24em] uppercase">
      <div class="container py-16">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
          <div>
            <h2 class="mb-4 text-2xl font-bold tracking-tight">
              {i18n.footer.buildingOn}
            </h2>
            <p class="text-muted-foreground max-w-lg text-sm leading-relaxed">
              {i18n.footer.softwareEngineer}
            </p>
          </div>
          <div class="lg:flex lg:flex-col lg:items-end lg:text-right">
            <h3
              class="text-muted-foreground/60 mb-4 text-xs font-semibold tracking-wider uppercase"
            >
              {i18n.footer.links}
            </h3>
            <ul class="space-y-3">
              <li>
                <a
                  href={`mailto:${SITE.email}`}
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {i18n.footer.email} →
                </a>
              </li>
              <li>
                <a
                  href={SITE.social.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {i18n.footer.github} →
                </a>
              </li>
              <li>
                <a
                  href="/rss.xml"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {i18n.footer.rss} →
                </a>
              </li>
              <li>
                <a
                  href={SITE.social.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted-foreground hover:text-foreground transition-colors"
                >
                  {i18n.footer.linkedin} →
                </a>
              </li>
            </ul>
          </div>
        </div>
        <div class="border-border text-muted-foreground/50 mt-16 border-t pt-6">
          <div class="flex items-center justify-between">
            <p>{SITE.name} / {new Date().getFullYear()}</p>
            <LanguageSwitcher
              currentLang={lang}
              currentPath={currentPath}
              label={i18n.language.footerNavigation}
              languageNames={i18n.language.names}
              getSwitchLabel={i18n.language.switchTo}
            />
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
