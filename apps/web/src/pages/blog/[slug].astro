---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostMetaCard from '@/components/Blog/PostMetaCard.astro'
import TableOfContents from '@/components/Blog/TableOfContents.astro'
import PostHero from '@/components/Blog/PostHero.astro'
import ArticleContent from '@/components/Blog/ArticleContent.astro'
import RelatedPosts from '@/components/Blog/RelatedPosts.astro'
import { getAllPosts } from '@/lib/cms'
import { readingTime } from '@/lib/reading-time'
import { getSlug } from '@/lib/content-graph'
import { render } from 'astro:content'
import { SITE } from '@/lib/site'
import { getImageUrl, getAdjacentPosts } from '@/lib/utils'
import { formatDate } from '@/lib/date'
import { getPostPath } from '@/lib/routes'
import type { CollectionEntry } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const routePosts = await getAllPosts({ includeNoindex: true })
  const publicPosts = await getAllPosts()

  return routePosts.map((post) => ({
    params: { slug: getSlug(post) },
    props: { post, allPosts: publicPosts },
  }))
}

interface Props {
  post: CollectionEntry<'posts'>
  allPosts: CollectionEntry<'posts'>[]
}

// ============================================================================
// Data Fetching
// ============================================================================

const siteUrl = Astro.site?.origin ?? ''
const slug = Astro.params.slug
const { post, allPosts } = Astro.props as Props
const isPreview = Astro.url.searchParams.get('preview') === 'true'

const { Content, headings } = await render(post)

// ============================================================================
// Post Data
// ============================================================================

const {
  title,
  excerpt,
  coverImage,
  publishedAt,
  updatedAt,
  tags,
  category,
  author = SITE.author,
} = post.data

const formattedDate = formatDate(publishedAt)
const updatedDate = updatedAt ? formatDate(updatedAt) : null

// Content metrics
const bodyText = post.body ?? ''
const wordCount = bodyText.trim().split(/\s+/).filter(Boolean).length
const readingTimeMin = readingTime(bodyText)

// ============================================================================
// Navigation & Related Posts
// ============================================================================

const currentIndex = allPosts.findIndex((entry) => getSlug(entry) === slug)
const { prev: prevPost, next: nextPost } = getAdjacentPosts(allPosts, currentIndex)

const relatedPosts = allPosts
  .filter((entry) => getSlug(entry) !== slug && entry.data.category === category)
  .slice(0, 3)

// ============================================================================
// SEO & Metadata
// ============================================================================

const canonicalUrl = new URL(getPostPath(post), siteUrl || Astro.url.origin).href
const publishedTime = publishedAt.toISOString()
const modifiedTime = updatedAt?.toISOString() ?? publishedTime

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  image: getImageUrl(coverImage, siteUrl),
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: {
    '@type': 'Person',
    name: author,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  keywords: [...tags, category],
} as const
---

<BaseLayout
  title={`${title} | ${SITE.name}`}
  description={excerpt}
  canonicalUrl={canonicalUrl}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={author}
  type="article"
  jsonLd={articleJsonLd}
  noindex={isPreview || post.data.noindex}
  {...coverImage && { image: coverImage }}
>
  <article class="min-h-screen" transition:name="post-detail">
    {
      isPreview && (
        <div class="border-b border-amber-500/30 bg-amber-500/10 px-4 py-3 text-center font-mono text-xs tracking-[0.22em] text-amber-200 uppercase">
          Preview mode
        </div>
      )
    }
    <!-- Hero Section -->
    <PostHero
      category={category}
      title={title}
      excerpt={excerpt}
      tags={tags}
      publishedAt={formattedDate}
      readingTime={readingTimeMin}
      {...coverImage && { coverImage }}
    />

    <!-- 3-Column Layout -->
    <div class="container py-8 lg:py-12">
      <div
        class="mx-auto grid max-w-7xl grid-cols-1 gap-8 lg:grid-cols-[200px_1fr_240px] lg:gap-12"
      >
        <!-- Left Sidebar: Table of Contents -->
        <aside class="order-2 lg:order-1">
          <TableOfContents headings={headings} />
        </aside>

        <!-- Center: Article Content -->
        <ArticleContent
          tags={tags}
          author={author}
          {...prevPost && { prevPost }}
          {...nextPost && { nextPost }}
        >
          <Content />
        </ArticleContent>

        <!-- Right Sidebar: Post Meta Card -->
        <aside class="order-3 hidden lg:block">
          <PostMetaCard
            author={author}
            publishedAt={formattedDate}
            readingTime={readingTimeMin}
            wordCount={wordCount}
            {...updatedDate && { updatedAt: updatedDate }}
          />
        </aside>
      </div>
    </div>

    <!-- Related Posts -->
    <RelatedPosts relatedPosts={relatedPosts} />
  </article>
</BaseLayout>
