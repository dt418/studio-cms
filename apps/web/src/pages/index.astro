---
import BaseLayout from '@/layouts/BaseLayout.astro'
import HeroSection from '@/components/HeroSection.astro'
import SectionHeader from '@/components/SectionHeader.astro'
import MetricCard from '@/components/MetricCard.astro'
import MarqueeSection from '@/components/MarqueeSection.astro'
import FeaturedWork from '@/components/FeaturedWork.astro'
import ArchiveSection from '@/components/ArchiveSection.astro'
import { getAllPosts, getAllCategories, getAllTags } from '@/lib/cms'
import { SITE } from '@/lib/site'

export const prerender = true

const posts = await getAllPosts()
const categories = await getAllCategories()
const allTags = await getAllTags()

const featuredPost = posts[0] ?? null
const recentPosts = posts.slice(1, 4)
const archivePosts = posts.slice(4)

const metrics = [
  {
    label: 'Latest',
    value: `${posts.length} posts`,
    category: 'Published writing',
    description:
      'Practical tutorials and guides on web development, TypeScript, and modern tooling.',
  },
  {
    label: 'Topics',
    value: `${categories.length} areas`,
    category: 'Coverage areas',
    description:
      'Deep dives across web development, tooling, architecture, and developer experience.',
  },
  {
    label: 'Tags',
    value: `${allTags.length} tags`,
    category: 'Keywords',
    description: 'Tagged and searchable content covering React, Astro, TypeScript, and more.',
  },
]
---

<BaseLayout
  title="Danh Thanh - Software Engineer & Developer Blog"
  description="Thoughts, tutorials, and guides on web development, TypeScript, and modern tooling."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: Astro.site?.origin,
    description: SITE.description,
    author: {
      '@type': 'Person',
      name: SITE.author,
      url: Astro.site?.origin,
      sameAs: [SITE.social.github, SITE.social.linkedin],
    },
  }}
>
  <HeroSection posts={posts.length} categories={categories.length} allTags={allTags.length}>
    <div slot="terminal" class="hidden items-end justify-end lg:flex">
      <div class="border-border bg-card/30 w-full max-w-lg border p-6">
        <div class="border-border mb-6 space-y-3 border-b pb-4">
          <p class="text-muted-foreground/50 font-mono text-[0.68rem] tracking-[0.28em] uppercase">
            who I help
          </p>
          <div class="text-muted-foreground/80 space-y-2 text-sm">
            <p>Developers building modern web products who need clear, practical insights.</p>
            <p>Topics: web development, TypeScript, Astro, React, and modern tooling.</p>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div class="space-y-1">
            <p
              class="text-muted-foreground/40 font-mono text-[0.66rem] tracking-[0.28em] uppercase"
            >
              01
            </p>
            <p class="text-lg leading-none font-medium">Tutorials</p>
          </div>
          <div class="space-y-1">
            <p
              class="text-muted-foreground/40 font-mono text-[0.66rem] tracking-[0.28em] uppercase"
            >
              02
            </p>
            <p class="text-lg leading-none font-medium">Guides</p>
          </div>
          <div class="space-y-1">
            <p
              class="text-muted-foreground/40 font-mono text-[0.66rem] tracking-[0.28em] uppercase"
            >
              03
            </p>
            <p class="text-lg leading-none font-medium">Notes</p>
          </div>
        </div>
      </div>
    </div>
  </HeroSection>

  <SectionHeader title="Latest insights">
    <h2 slot="header" class="mt-4 max-w-xl text-2xl font-semibold tracking-tight lg:text-3xl">
      Practical knowledge for modern developers.
    </h2>
    <div class="mt-6 grid gap-4 sm:mt-8 sm:gap-5 lg:grid-cols-3">
      {
        metrics.map((item) => (
          <MetricCard
            label={item.label}
            value={item.value}
            category={item.category}
            description={item.description}
            spotlight
          />
        ))
      }
    </div>
  </SectionHeader>

  <MarqueeSection items={categories} />

  <FeaturedWork featuredPost={featuredPost} recentPosts={recentPosts} />

  <ArchiveSection posts={archivePosts} />
</BaseLayout>
