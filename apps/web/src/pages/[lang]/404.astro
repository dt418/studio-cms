---
import NotFoundPage from '@/components/NotFoundPage.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { isValidLocale } from '@/lib/content-utils'
import { DEFAULT_LOCALE, getTranslations, type Language } from '@/lib/i18n'
import { getBlogPath, getHomePath } from '@/lib/routes'
import { SITE } from '@/lib/site'

export const prerender = true

export function getStaticPaths() {
  return ['vi', 'en'].map((lang) => ({ params: { lang } }))
}

const langParam = Astro.params.lang
const lang: Language = langParam && isValidLocale(langParam) ? langParam : DEFAULT_LOCALE
const i18n = getTranslations(lang)
const homePath = lang === 'vi' ? '/vi/' : getHomePath(lang)
const blogPath = getBlogPath(lang)
const tracePath = `${Astro.url.host}${Astro.url.pathname}`
const copy = {
  allPosts: i18n.errors.allPosts,
  description: i18n.errors.description404,
  footerRole: i18n.errors.footerRole,
  githubLabel: i18n.errors.githubLabel,
  goHome: i18n.errors.goHome,
  linkedinLabel: i18n.errors.linkedinLabel,
  maybeLookingFor: i18n.errors.maybeLookingFor,
  quickLinks404: i18n.errors.quickLinks404,
  rssFeed: i18n.errors.rssFeed,
  status: i18n.errors.status,
  terminalContentType: i18n.errors.terminalContentType,
  terminalLabel404: i18n.errors.terminalLabel404,
  terminalServer: i18n.errors.terminalServer,
  terminalTitle: i18n.errors.terminalTitle,
  title: i18n.errors.subtitle404,
  tracePrefix: i18n.errors.tracePrefix,
  viewBlog: i18n.errors.viewBlog,
}
---

<BaseLayout
  title={`${i18n.errors.notFound} | ${SITE.name}`}
  lang={lang}
  noindex
  currentPath={`/${lang}`}
>
  <NotFoundPage
    blogPath={blogPath}
    copy={copy}
    homePath={homePath}
    lang={lang}
    tracePath={tracePath}
  />
</BaseLayout>
