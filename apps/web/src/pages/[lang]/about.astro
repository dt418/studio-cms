---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getTranslations } from '@/lib/i18n'
import { SITE } from '@/lib/site'
import { getCanonicalUrl, getAlternateUrls, isValidLocale } from '@/lib/content-utils'
import type { SupportedLocale } from '@/lib/cms'

export const prerender = true

export async function getStaticPaths() {
  const locales: SupportedLocale[] = ['vi', 'en']
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }))
}

const langParam = Astro.params.lang ?? 'vi'
const lang = isValidLocale(langParam) ? langParam : 'vi'
const siteUrl = Astro.site?.origin ?? ''
const i18n = getTranslations(lang)
const title = lang === 'vi' ? 'Về tôi' : 'About'
const description =
  lang === 'vi'
    ? 'Thông tin về tác giả, định hướng nội dung và cách liên hệ hợp tác.'
    : 'About the author, writing focus, and collaboration contact.'
---

<BaseLayout
  title={`${title} | ${SITE.name}`}
  description={description}
  canonicalUrl={getCanonicalUrl(lang, '/about', siteUrl)}
  lang={lang}
  currentPath={`/${lang}/about`}
  alternateUrls={getAlternateUrls('/about', siteUrl)}
>
  <section class="container py-14 sm:py-20">
    <p class="text-muted-foreground text-xs tracking-[0.22em] uppercase">{i18n.nav.about}</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{SITE.author}</h1>
    <p class="text-muted-foreground mt-6 max-w-2xl leading-relaxed">
      {i18n.footer.softwareEngineer}
    </p>
    <p class="text-muted-foreground mt-4 max-w-2xl leading-relaxed">{i18n.hero.description}</p>
    <div class="mt-8">
      <a href={`mailto:${SITE.email}`} class="text-sm tracking-[0.18em] uppercase">
        {lang === 'vi' ? 'Liên hệ hợp tác' : 'Contact for collaboration'} →
      </a>
    </div>
  </section>
</BaseLayout>
