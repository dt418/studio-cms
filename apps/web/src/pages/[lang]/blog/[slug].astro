---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostMetaCard from '@/components/Blog/PostMetaCard.astro'
import TableOfContents from '@/components/Blog/TableOfContents.astro'
import PostHero from '@/components/Blog/PostHero.astro'
import ArticleContent from '@/components/Blog/ArticleContent.astro'
import RelatedPosts from '@/components/Blog/RelatedPosts.astro'
import { getLocalizedPosts, getPostSlug, type SupportedLocale } from '@/lib/cms'
import { readingTime } from '@/lib/reading-time'
import { render } from 'astro:content'
import { SITE } from '@/lib/site'
import { getImageUrl, getAdjacentPosts } from '@/lib/post'
import { formatDate } from '@/lib/date'
import { getBlogPath } from '@/lib/routes'
import { getTranslations } from '@/lib/i18n'
import { getCanonicalUrl, getAlternateUrls, isValidLocale } from '@/lib/content-utils'
import type { CollectionEntry } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const locales: SupportedLocale[] = ['vi', 'en']
  const paths: {
    params: { lang: SupportedLocale; slug: string }
    props: { post: CollectionEntry<'posts'>; allPosts: CollectionEntry<'posts'>[] }
  }[] = []

  for (const locale of locales) {
    const posts = await getLocalizedPosts(locale, { includeNoindex: true })
    const visiblePosts = posts.filter((post) => !post.data.noindex)

    for (const post of visiblePosts) {
      paths.push({
        params: { lang: locale, slug: getPostSlug(post) },
        props: { post, allPosts: visiblePosts },
      })
    }
  }

  return paths
}

interface Props {
  post: CollectionEntry<'posts'>
  allPosts: CollectionEntry<'posts'>[]
}

const siteUrl = Astro.site?.origin ?? ''
const langParam = Astro.params.lang ?? 'vi'
const lang = isValidLocale(langParam) ? langParam : 'vi'
const slug = Astro.params.slug
const { post, allPosts } = Astro.props as Props

const { Content, headings } = await render(post)

const {
  title,
  excerpt,
  coverImage,
  publishedAt,
  updatedAt,
  tags,
  category,
  author = SITE.author,
} = post.data

const formattedDate = formatDate(publishedAt)
const updatedDate = updatedAt ? formatDate(updatedAt) : null

const bodyText = post.body ?? ''
const wordCount = bodyText.trim().split(/\s+/).filter(Boolean).length
const readingTimeMin = readingTime(bodyText)

const i18n = getTranslations(lang)

const currentIndex = allPosts.findIndex((entry) => getPostSlug(entry) === slug)
const { prev: prevPost, next: nextPost } = getAdjacentPosts(allPosts, currentIndex)

const relatedPosts = allPosts
  .filter((entry) => getPostSlug(entry) !== slug && entry.data.category === category)
  .slice(0, 3)

const canonicalUrl = getCanonicalUrl(lang, `/blog/${slug}`, siteUrl || Astro.url.origin)
const publishedTime = publishedAt.toISOString()
const modifiedTime = updatedAt?.toISOString() ?? publishedTime
const alternateUrls = getAlternateUrls(`/blog/${slug}`, siteUrl)

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  image: getImageUrl(coverImage, siteUrl),
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: {
    '@type': 'Person',
    name: author,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  keywords: [...tags, category],
} as const

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: i18n.schema.home,
      item: `${siteUrl}/${lang}`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: i18n.schema.blog,
      item: getBlogPath(lang),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
    },
  ],
} as const
---

<style is:global>
  [data-pagefind-filter],
  [data-pagefind-sort] {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>

<BaseLayout
  title={`${title} | ${SITE.name}`}
  description={excerpt}
  canonicalUrl={canonicalUrl}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={author}
  type="article"
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
  noindex={post.data.noindex}
  lang={lang}
  currentPath={`/${lang}/blog/${slug}`}
  alternateUrls={alternateUrls}
  {...coverImage && { image: coverImage }}
>
  <article class="min-h-screen" data-pagefind-body transition:name="post-detail">
    <span data-pagefind-filter="category">{category}</span>
    {tags.map((tag) => <span data-pagefind-filter="tag">{tag}</span>)}
    <span data-pagefind-sort="date">{publishedAt.getTime()}</span>
    <span data-pagefind-sort="title">{title}</span>
    <PostHero
      category={category}
      title={title}
      excerpt={excerpt}
      tags={tags}
      publishedAt={formattedDate}
      readingTime={readingTimeMin}
      lang={lang}
      i18n={{ ...i18n.schema, minRead: i18n.post.minRead }}
      {...coverImage && { coverImage }}
    />

    <div class="container py-8 lg:py-12">
      <div
        class="mx-auto grid max-w-7xl grid-cols-1 gap-8 lg:grid-cols-[200px_1fr_240px] lg:gap-12"
      >
        <aside class="order-2 lg:order-1">
          <TableOfContents headings={headings} i18n={i18n.post} />
        </aside>

        <ArticleContent
          tags={tags}
          author={author}
          {...prevPost && { prevPost }}
          {...nextPost && { nextPost }}
          i18n={i18n}
        >
          <Content />
        </ArticleContent>

        <aside class="order-3 hidden lg:block">
          <PostMetaCard
            author={author}
            publishedAt={formattedDate}
            readingTime={readingTimeMin}
            wordCount={wordCount}
            i18n={i18n.post}
            {...updatedDate && { updatedAt: updatedDate }}
          />
        </aside>
      </div>
    </div>

    <RelatedPosts relatedPosts={relatedPosts} i18n={i18n.post} />
  </article>
</BaseLayout>
