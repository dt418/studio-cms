---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogFilter from '@/components/BlogFilter.astro'
import BlogCard from '@/components/BlogCard.astro'
import BackLink from '@/components/Blog/BackLink.astro'
import CategoryCloud from '@/components/Blog/CategoryCloud.astro'
import { getPostsByCategory, getAllCategories, getAllTags } from '@/lib/cms'
import { SITE } from '@/lib/site'

export const prerender = true

export async function getStaticPaths() {
  const categories = await getAllCategories()

  return categories.map((category) => ({
    params: { category },
    props: { category },
  }))
}

const rawCategory = Astro.params.category ?? ''
const category =
  Astro.props.category ??
  (() => {
    try {
      return decodeURIComponent(rawCategory)
    } catch {
      return rawCategory
    }
  })()
const posts = await getPostsByCategory(category)
const allCategories = await getAllCategories()
const allTags = await getAllTags()
const canonicalUrl = new URL(`/categories/${encodeURIComponent(category)}`, Astro.site).href
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Posts in ${category}`,
  description: `All posts in category ${category}`,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: SITE.name,
    url: Astro.site?.origin,
  },
}
---

<BaseLayout
  title={`${category} | ${SITE.name}`}
  description={`All posts in category ${category}`}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <section class="container py-16">
    <div class="mb-12">
      <BackLink href="/blog" />
      <h1 class="mb-2 text-4xl font-bold tracking-tight">Category: {category}</h1>
      <p class="text-muted-foreground text-lg">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'} in "{category}"
      </p>
    </div>

    <CategoryCloud categories={allCategories} currentCategory={category} />

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="mt-12">
      <h2 class="text-muted-foreground mb-4 text-sm font-medium">Search & Filter</h2>
      <BlogFilter
        posts={posts}
        categories={allCategories}
        tags={allTags}
        initialCategory={category}
      />
    </div>
  </section>
</BaseLayout>
