---
import type { Language } from '@/lib/i18n'
import { SITE } from '@/lib/site'
import { cn } from '@/lib/utils'

interface NotFoundCopy {
  allPosts: string
  description: string
  footerRole: string
  githubLabel: string
  goHome: string
  linkedinLabel: string
  maybeLookingFor: string
  quickLinks404: string
  rssFeed: string
  status: string
  terminalContentType: string
  terminalLabel404: string
  terminalServer: string
  terminalTitle: string
  title: string
  tracePrefix: string
  viewBlog: string
}

interface Props {
  blogPath: string
  copy: NotFoundCopy
  homePath: string
  lang: Language
  tracePath: string
}

const { blogPath, copy, homePath, lang, tracePath } = Astro.props
const quickLinks = [
  { href: blogPath, label: copy.allPosts },
  { href: SITE.social.github, label: copy.githubLabel, external: true },
  { href: SITE.social.linkedin, label: copy.linkedinLabel, external: true },
  { href: '/rss.xml', label: copy.rssFeed },
]
---

<main class="relative isolate overflow-hidden bg-[#050608] text-zinc-100">
  <div class="pointer-events-none absolute inset-0 -z-10 opacity-80">
    <div class="absolute -top-40 -left-32 h-96 w-96 rounded-full bg-cyan-500/15 blur-3xl"></div>
    <div class="absolute top-1/3 -right-24 h-112 w-md rounded-full bg-red-500/12 blur-3xl"></div>
    <div
      class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.035)_1px,transparent_1px)] bg-size-[48px_48px]"
    >
    </div>
  </div>

  <div
    class="container grid min-h-[calc(100svh-5rem)] items-center gap-12 py-16 lg:grid-cols-[minmax(0,1.04fr)_minmax(360px,0.84fr)] lg:py-24"
  >
    <section class="space-y-8">
      <div class="glitch-wrap relative inline-block font-mono" aria-label="404">
        <span
          class="big-404 relative z-10 block text-[8rem] leading-none font-black tracking-[-0.12em] text-white sm:text-[11rem] lg:text-[13rem]"
        >
          404
        </span>
        <span
          class="big-404 glitch-red absolute inset-0 block text-[8rem] leading-none font-black tracking-[-0.12em] text-red-500/70 sm:text-[11rem] lg:text-[13rem]"
          aria-hidden="true"
        >
          404
        </span>
        <span
          class="big-404 glitch-cyan absolute inset-0 block text-[8rem] leading-none font-black tracking-[-0.12em] text-cyan-300/70 sm:text-[11rem] lg:text-[13rem]"
          aria-hidden="true"
        >
          404
        </span>
      </div>

      <div
        class="flex items-center gap-3 font-mono text-xs tracking-[0.28em] text-zinc-400 uppercase"
      >
        <span class="status-pulse-dot relative flex h-3 w-3" aria-hidden="true">
          <span class="status-pulse-ring absolute inset-0 rounded-full bg-red-500/70"></span>
          <span
            class="status-pulse-core relative inline-flex h-3 w-3 rounded-full bg-red-500 shadow-[0_0_18px_rgba(239,68,68,0.9)]"
          ></span>
        </span>
        <span>{copy.status}</span>
      </div>

      <div class="max-w-3xl space-y-5">
        <h1
          class="text-4xl leading-[0.96] font-semibold tracking-[-0.05em] text-balance text-white sm:text-6xl lg:text-7xl"
        >
          {copy.title}
        </h1>
        <p class="max-w-2xl text-base leading-8 text-zinc-400 sm:text-lg">{copy.description}</p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={homePath}
          class="btn btn-primary group hover:shadow-primary/20 min-h-12 px-6 hover:-translate-y-0.5 hover:shadow-lg"
        >
          <span
            class="transition-transform duration-200 group-hover:-translate-x-1"
            aria-hidden="true">←</span
          >
          <span>{copy.goHome}</span>
        </a>
        <a
          href={blogPath}
          class="btn btn-outline group hover:shadow-foreground/10 min-h-12 px-6 hover:-translate-y-0.5 hover:shadow-lg"
        >
          <span>{copy.viewBlog}</span>
          <span
            class="transition-transform duration-200 group-hover:translate-x-1"
            aria-hidden="true">→</span
          >
        </a>
      </div>
    </section>

    <section aria-label={copy.terminalLabel404} class="space-y-5 font-mono">
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-zinc-950/80 shadow-2xl shadow-cyan-950/30 backdrop-blur"
      >
        <div class="flex h-12 items-center gap-2 border-b border-white/10 bg-white/4 px-4">
          <span class="h-3 w-3 rounded-full bg-red-500" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-400" aria-hidden="true"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400" aria-hidden="true"></span>
          <span class="ml-3 text-xs tracking-wide text-zinc-500">{copy.terminalTitle}</span>
        </div>

        <div class="space-y-3 p-5 font-mono text-sm leading-relaxed sm:p-6">
          <p>
            <span class="text-zinc-600">~</span>
            <span class="text-zinc-100">curl -I {tracePath}</span>
          </p>
          <p class="text-red-400">HTTP/2 404</p>
          <p class="text-zinc-500">{copy.terminalContentType}</p>
          <p class="text-zinc-500">{copy.terminalServer}</p>
          <div class="h-3" aria-hidden="true"></div>
          <p><span class="text-zinc-600">~</span> <span class="text-zinc-100">echo $?</span></p>
          <p class="text-red-400">22</p>
          <div class="h-3" aria-hidden="true"></div>
          <p>
            <span class="text-zinc-600">~</span>
            <span class="text-zinc-100"
              >cd /{lang} && ls<span
                class="ml-1 inline-block h-4 w-2 animate-pulse bg-zinc-100 align-middle"
                aria-hidden="true"></span></span
            >
          </p>
          <p class="text-cyan-300">blog/ rss.xml</p>
        </div>
      </div>

      <nav aria-label={copy.quickLinks404} class="card-hover rounded-2xl p-5 font-sans">
        <p class="text-muted-foreground mb-3 text-xs tracking-[0.28em] uppercase">
          {copy.maybeLookingFor}
        </p>
        <ul class="space-y-2">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={cn(
                    'group border-border bg-card text-card-foreground hover:border-primary/40 hover:bg-accent hover:text-accent-foreground hover:shadow-primary/10 focus-visible:ring-ring/50 flex items-center justify-between rounded-sm border px-3 py-3 text-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg focus-visible:ring-[3px] focus-visible:outline-none'
                  )}
                  {...(link.external && { target: '_blank', rel: 'noopener noreferrer' })}
                >
                  <span>{link.label}</span>
                  <span
                    class="text-muted-foreground group-hover:text-accent-foreground transition-transform duration-200 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <p class="border-l border-cyan-300/40 pl-4 text-xs break-all text-zinc-500">
        {copy.tracePrefix}<span class="text-zinc-300">{tracePath}</span>
      </p>

      <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-zinc-600">
        <span>{SITE.name} / 2026</span>
        <span>{copy.footerRole}</span>
      </div>
    </section>
  </div>
</main>

<style>
  .glitch-red {
    animation: glitch-red 2.7s infinite steps(2, jump-none);
    clip-path: polygon(0 12%, 100% 8%, 100% 32%, 0 36%);
    transform: translate(0.04em, 0.015em);
  }

  .glitch-cyan {
    animation: glitch-cyan 3.1s infinite steps(2, jump-none);
    clip-path: polygon(0 58%, 100% 54%, 100% 86%, 0 90%);
    transform: translate(-0.035em, -0.012em);
  }

  .status-pulse-ring {
    animation: status-pulse-ring 1.7s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .status-pulse-core {
    animation: status-pulse-core 1.7s ease-in-out infinite;
  }

  @keyframes status-pulse-ring {
    0% {
      opacity: 0.72;
      transform: scale(0.75);
    }

    70%,
    100% {
      opacity: 0;
      transform: scale(2.65);
    }
  }

  @keyframes status-pulse-core {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }

    50% {
      opacity: 0.72;
      transform: scale(0.72);
    }
  }

  @keyframes glitch-red {
    0%,
    80%,
    100% {
      opacity: 0.18;
      transform: translate(0.035em, 0.012em);
    }

    82% {
      opacity: 0.8;
      transform: translate(0.08em, -0.01em);
    }
  }

  @keyframes glitch-cyan {
    0%,
    74%,
    100% {
      opacity: 0.16;
      transform: translate(-0.03em, -0.012em);
    }

    76% {
      opacity: 0.75;
      transform: translate(-0.075em, 0.014em);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-red,
    .glitch-cyan,
    .status-pulse-core,
    .status-pulse-ring {
      animation: none;
    }
  }
</style>
