---
interface StatCard {
  value: number | string
  label: string
}

interface Props {
  stats: StatCard[]
}

const { stats } = Astro.props
---

<div class="mb-10 grid grid-cols-2 gap-3 sm:grid-cols-4" data-testid="blog-stats-grid">
  {
    stats.map((stat) => (
      <div class="border border-white/5 bg-white/2 p-4">
        <div class="font-mono text-2xl font-bold tracking-tight tabular-nums">{stat.value}</div>
        <div class="text-muted-foreground/40 mt-1.5 font-mono text-xs tracking-wider uppercase">
          {stat.label}
        </div>
      </div>
    ))
  }
</div>
