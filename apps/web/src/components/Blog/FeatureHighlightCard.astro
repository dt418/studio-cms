---
interface Props {
  title: string
  description: string
  icon?: string
}

const { title, description, icon = '✨' } = Astro.props
---

<article class="card-hover my-8">
  <div class="flex items-start gap-4">
    <div
      class="bg-primary/10 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-lg"
    >
      {icon}
    </div>
    <div>
      <h3 class="text-foreground mb-1 text-lg font-semibold">{title}</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">{description}</p>
    </div>
  </div>
</article>
