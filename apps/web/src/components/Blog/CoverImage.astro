---
import { Image } from 'astro:assets'
import { getOptimizedCoverImage } from '@/lib/cover-images'

interface Props {
  coverImage: string
  title: string
}

const { coverImage, title } = Astro.props
const optimizedCoverImage = getOptimizedCoverImage(coverImage)
---

<div class="border-border mt-8 overflow-hidden rounded-xl border">
  {
    optimizedCoverImage ? (
      <Image
        src={optimizedCoverImage}
        alt={title}
        class="h-auto w-full object-cover"
        width="1200"
        height="630"
        layout="constrained"
        sizes="(max-width: 768px) calc(100vw - 4rem), 60vw"
        fetchpriority="high"
        loading="eager"
        decoding="sync"
      />
    ) : (
      <Image
        src={coverImage}
        alt={title}
        class="h-auto w-full object-cover"
        width="1200"
        height="630"
        layout="constrained"
        sizes="(max-width: 768px) calc(100vw - 4rem), 60vw"
        fetchpriority="high"
        loading="eager"
        decoding="sync"
      />
    )
  }
</div>
