---
import PostNavLink from './PostNavLink.astro'
import type { CollectionEntry } from 'astro:content'

interface Props {
  prevPost?: CollectionEntry<'posts'>
  nextPost?: CollectionEntry<'posts'>
  i18n?: {
    postNavigation: string
    prevPost: string
    nextPost: string
  }
}

const { prevPost, nextPost, i18n } = Astro.props
---

<nav class="mt-8 grid gap-4 md:grid-cols-2" aria-label={i18n?.postNavigation ?? 'Post navigation'}>
  {prevPost && <PostNavLink post={prevPost} direction="prev" {...(i18n && { i18n })} />}
  {nextPost && <PostNavLink post={nextPost} direction="next" {...(i18n && { i18n })} />}
</nav>
