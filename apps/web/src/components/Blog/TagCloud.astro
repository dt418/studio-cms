---
interface Props {
  tags: string[]
  currentTag?: string
}

import { getTagPath } from '@/lib/routes'

const { tags, currentTag } = Astro.props
---

<div class="mb-8">
  <h2 class="text-muted-foreground mb-3 text-sm font-medium">All Tags</h2>
  <div class="flex flex-wrap gap-2">
    {
      tags.map((tagName) => (
        <a
          href={getTagPath(tagName)}
          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors"
          class:list={[
            tagName === currentTag
              ? 'bg-primary text-primary-foreground border-transparent'
              : 'hover:bg-accent hover:text-accent-foreground',
          ]}
        >
          {tagName}
        </a>
      ))
    }
  </div>
</div>
