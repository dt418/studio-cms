---
interface Props {
  author: string
  publishedAt: string
  publishedAtIso: string
  updatedAt?: string
  updatedAtIso?: string
  readingTime: number
  wordCount: number
  i18n?: {
    readingDetails: string
    author: string
    published: string
    updated: string
    minRead: string
    words: string
    share: string
    shareOnX: string
    copyLink: string
  }
}

const {
  author,
  publishedAt,
  publishedAtIso,
  updatedAt,
  updatedAtIso,
  readingTime,
  wordCount,
  i18n = {
    readingDetails: 'Reading Details',
    author: 'Author',
    published: 'Published',
    updated: 'Updated',
    minRead: 'Min read',
    words: 'Words',
    share: 'Share',
    shareOnX: 'Share on X',
    copyLink: 'Copy link',
  },
} = Astro.props
---

<div class="sticky top-24 hidden xl:block">
  <article class="card-hover space-y-5">
    <h3 class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.28em] uppercase">
      {i18n.readingDetails}
    </h3>

    <div class="space-y-4">
      <div>
        <p
          class="text-muted-foreground/50 mb-1 font-mono text-[0.62rem] tracking-[0.22em] uppercase"
        >
          {i18n.author}
        </p>
        <p class="text-foreground text-sm font-medium">{author}</p>
      </div>

      <div>
        <p
          class="text-muted-foreground/50 mb-1 font-mono text-[0.62rem] tracking-[0.22em] uppercase"
        >
          {i18n.published}
        </p>
        <time class="text-foreground text-sm" datetime={publishedAtIso}>{publishedAt}</time>
      </div>

      {
        updatedAt && (
          <div>
            <p class="text-muted-foreground/50 mb-1 font-mono text-[0.62rem] tracking-[0.22em] uppercase">
              {i18n.updated}
            </p>
            <time class="text-foreground text-sm" datetime={updatedAtIso ?? updatedAt}>
              {updatedAt}
            </time>
          </div>
        )
      }

      <div class="bg-border h-px"></div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-foreground text-2xl font-bold tabular-nums">{readingTime}</p>
          <p class="text-muted-foreground/60 mt-0.5 text-xs">{i18n.minRead}</p>
        </div>
        <div>
          <p class="text-foreground text-2xl font-bold tabular-nums">
            {wordCount.toLocaleString()}
          </p>
          <p class="text-muted-foreground/60 mt-0.5 text-xs">{i18n.words}</p>
        </div>
      </div>
    </div>

    <div class="bg-border h-px"></div>
    <div>
      <p class="text-muted-foreground/50 mb-3 font-mono text-[0.62rem] tracking-[0.22em] uppercase">
        {i18n.share}
      </p>
      <div class="flex gap-2">
        <button
          class="border-border text-muted-foreground hover:text-foreground hover:bg-accent inline-flex h-8 w-8 items-center justify-center rounded-md border transition-colors"
          aria-label={i18n.shareOnX}
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path></svg
          >
        </button>
        <button
          class="border-border text-muted-foreground hover:text-foreground hover:bg-accent inline-flex h-8 w-8 items-center justify-center rounded-md border transition-colors"
          aria-label={i18n.copyLink}
        >
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg
          >
        </button>
      </div>
    </div>
  </article>
</div>
