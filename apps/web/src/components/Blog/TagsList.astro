---
import type { CollectionEntry } from 'astro:content'
import { getTagPath } from '@/lib/routes'
import { getPostLocale } from '@/lib/content-utils'

interface Props {
  tags: string[]
  post?: CollectionEntry<'posts'>
  locale?: string
}

const { tags, post, locale } = Astro.props
const postLocale = locale ?? (post ? getPostLocale(post) : 'vi')
---

<div class="flex flex-wrap gap-3">
  {
    tags.map((tag) => (
      <a
        href={getTagPath(tag, postLocale as 'vi' | 'en')}
        class="border-border text-muted-foreground hover:text-foreground hover:bg-accent inline-flex min-h-11 items-center rounded-full border px-4 py-2 text-sm font-medium transition-colors"
      >
        #{tag}
      </a>
    ))
  }
</div>
