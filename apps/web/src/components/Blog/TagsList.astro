---
interface Props {
  tags: string[]
}

import { getTagPath } from '@/lib/routes'

const { tags } = Astro.props
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <a
        href={getTagPath(tag)}
        class="border-border text-muted-foreground hover:text-foreground hover:bg-accent inline-flex items-center rounded-full border px-3 py-1 text-xs font-medium transition-colors"
      >
        #{tag}
      </a>
    ))
  }
</div>
