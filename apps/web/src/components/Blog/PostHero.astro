---
import PostHeader from './PostHeader.astro'

interface Props {
  category: string
  title: string
  excerpt: string
  tags: string[]
  publishedAt: string
  readingTime: number
  lang?: string
  coverImage?: string
  i18n?: {
    home: string
    blog: string
    minRead: string
  }
}

const { category, title, excerpt, tags, publishedAt, readingTime, lang, coverImage, i18n } =
  Astro.props
---

<section class="border-border border-b">
  <div class="container py-12 lg:py-16">
    <div class="mx-auto max-w-4xl">
      <PostHeader
        category={category}
        title={title}
        excerpt={excerpt}
        tags={tags}
        publishedAt={publishedAt}
        readingTime={readingTime}
        {...lang !== undefined ? { lang } : {}}
        {...i18n !== undefined ? { i18n } : {}}
        {...coverImage && { coverImage }}
      />
    </div>
  </div>
</section>
