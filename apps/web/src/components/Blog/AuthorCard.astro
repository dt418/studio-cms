---
import { getAuthorInitials } from '@/lib/post'

interface Props {
  author: string
  i18n?: {
    role: string
  }
}

const { author, i18n = { role: 'Writer & Developer' } } = Astro.props
---

<article class="card-hover flex items-center gap-4">
  <div
    class="bg-primary/10 text-primary flex h-12 w-12 items-center justify-center rounded-full text-base font-semibold"
  >
    {getAuthorInitials(author)}
  </div>
  <div>
    <p class="text-foreground font-medium">{author}</p>
    <p class="text-muted-foreground text-sm">{i18n.role}</p>
  </div>
</article>
