---
import type { CollectionEntry } from 'astro:content'
import { getCategoryPath } from '@/lib/routes'
import { getPostLocale } from '@/lib/content-utils'

interface Props {
  categories: string[]
  currentCategory?: string
  locale?: string
  post?: CollectionEntry<'posts'>
}

const { categories, currentCategory, locale, post } = Astro.props
const postLocale = locale ?? (post ? getPostLocale(post) : 'vi')
---

<div class="mb-8">
  <h2 class="text-muted-foreground mb-3 text-sm font-medium">All Categories</h2>
  <div class="flex flex-wrap gap-2">
    {
      categories.map((cat) => (
        <a
          href={getCategoryPath(cat, postLocale as 'vi' | 'en')}
          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors"
          class:list={[
            cat === currentCategory
              ? 'bg-primary text-primary-foreground border-transparent'
              : 'hover:bg-accent hover:text-accent-foreground',
          ]}
        >
          {cat}
        </a>
      ))
    }
  </div>
</div>
