---
import type { CollectionEntry } from 'astro:content'
import TagsList from './TagsList.astro'
import AuthorCard from './AuthorCard.astro'
import PostNavigation from './PostNavigation.astro'

interface Props {
  tags: string[]
  author: string
  prevPost?: CollectionEntry<'posts'>
  nextPost?: CollectionEntry<'posts'>
  i18n?: {
    author: {
      role: string
    }
    post: {
      postNavigation: string
      prevPost: string
      nextPost: string
    }
  }
}

const { tags, author, prevPost, nextPost, i18n } = Astro.props
---

<div class="order-1 min-w-0 lg:order-2">
  <div class="prose prose-lg">
    <slot />
  </div>

  <!-- Tags -->
  <footer class="border-border mt-12 border-t pt-8">
    <div class="mb-8 flex flex-wrap gap-2">
      <TagsList tags={tags} />
    </div>

    <!-- Author Card -->
    <AuthorCard author={author} {...i18n?.author && { i18n: i18n.author }} />

    <!-- Prev/Next Navigation -->
    <PostNavigation
      {...prevPost && { prevPost }}
      {...nextPost && { nextPost }}
      {...i18n?.post && { i18n: i18n.post }}
    />
  </footer>
</div>
