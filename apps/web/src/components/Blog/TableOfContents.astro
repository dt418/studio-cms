---
export interface Props {
  headings: { depth: number; slug: string; text: string }[]
}

const { headings } = Astro.props
const filteredHeadings = headings.filter((heading) => heading.depth <= 3)
---

{
  filteredHeadings.length > 0 && (
    <nav id="toc" class="sticky top-24 hidden lg:block" aria-label="Table of contents">
      <p class="text-muted-foreground/60 mb-4 text-xs font-semibold tracking-wider uppercase">
        On this page
      </p>
      <ul class="border-border space-y-1 border-l p-4">
        {filteredHeadings.map((heading) => (
          <li>
            <a
              href={`#${heading.slug}`}
              class="toc-link text-muted-foreground hover:text-foreground -ml-px block border-l-2 border-transparent py-1.5 text-sm transition-all duration-200"
              data-depth={heading.depth}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc-link[data-depth='2'] {
    padding-left: 1rem;
  }
  .toc-link[data-depth='3'] {
    padding-left: 1.75rem;
    font-size: 0.8rem;
  }
  .toc-link.active {
    color: var(--foreground);
    border-color: var(--primary);
    font-weight: 500;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toc = document.getElementById('toc')
    if (!toc) {
      return
    }
    toc.classList.remove('hidden')

    const links = toc.querySelectorAll<HTMLAnchorElement>('.toc-link')
    const headings: HTMLHeadingElement[] = []

    links.forEach((link) => {
      const slug = link.getAttribute('href')?.slice(1)
      if (slug) {
        const heading = document.getElementById(slug)
        if (heading) {
          headings.push(heading as HTMLHeadingElement)
        }
      }
    })

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((link) => link.classList.remove('active'))
            const activeLink = toc.querySelector<HTMLAnchorElement>(`a[href="#${entry.target.id}"]`)
            activeLink?.classList.add('active')
          }
        })
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    )

    headings.forEach((heading) => observer.observe(heading))
  })
</script>
