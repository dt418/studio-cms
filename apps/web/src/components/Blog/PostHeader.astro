---
import Breadcrumb from './Breadcrumb.astro'
import TagsList from './TagsList.astro'
import PostMetadata from './PostMetadata.astro'
import CoverImage from './CoverImage.astro'

interface Props {
  category: string
  title: string
  excerpt: string
  tags: string[]
  publishedAt: string
  readingTime: number
  coverImage?: string
}

const { category, title, excerpt, tags, publishedAt, readingTime, coverImage } = Astro.props
---

<div class="space-y-6">
  <Breadcrumb title={title} />

  <!-- Title -->
  <h1
    class="text-foreground text-4xl leading-[1.1] font-bold tracking-tight md:text-5xl lg:text-6xl"
  >
    {title}
  </h1>

  <!-- Excerpt -->
  <p class="text-muted-foreground max-w-2xl text-lg leading-relaxed md:text-xl">
    {excerpt}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    <span
      class="bg-primary/10 text-primary border-primary/20 inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold"
    >
      {category}
    </span>
    <TagsList tags={tags} />
  </div>

  <PostMetadata publishedAt={publishedAt} readingTime={readingTime} />

  <!-- Divider -->
  <div class="bg-border h-px"></div>
</div>

{coverImage && <CoverImage coverImage={coverImage} title={title} />}
