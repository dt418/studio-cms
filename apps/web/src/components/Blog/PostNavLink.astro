---
import { formatDate } from '@/lib/date'
import { getPostPath } from '@/lib/routes'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
  direction: 'prev' | 'next'
}

const { post, direction } = Astro.props
const postData = post.data || null
const isPrev = direction === 'prev'
const postPath = getPostPath(post)
---

<a
  href={postPath}
  class={`card-hover group flex flex-col gap-2 p-4 border border-border rounded-lg hover:border-primary/50 transition-colors ${
    isPrev ? '' : 'text-right'
  }`}
  aria-label={`${isPrev ? 'Previous' : 'Next'} post: ${postData?.title}`}
>
  <p class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.22em] uppercase">
    {isPrev ? 'Previous Post' : 'Next Post'}
  </p>
  <p
    class="text-foreground group-hover:text-primary line-clamp-2 text-sm font-medium transition-colors"
  >
    {isPrev ? '← ' : ''}
    {postData?.title ?? null}
    {isPrev ? '' : ' →'}
  </p>
  <p class="text-muted-foreground text-xs">
    {postData?.category && `${postData.category} · `}{formatDate(postData?.publishedAt)}
  </p>
</a>
