---
interface Props {
  src: string
  alt: string
  width: number
  height: number
  caption?: string
}

const { src, alt, width, height, caption } = Astro.props
---

<figure class="my-8">
  <div class="border-border overflow-hidden rounded-xl border">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      class="h-auto w-full object-cover"
      sizes="(max-width: 768px) 100vw, 800px"
      loading="lazy"
      decoding="async"
    />
  </div>
  {
    caption && (
      <figcaption class="text-muted-foreground mt-3 text-center text-sm italic">
        {caption}
      </figcaption>
    )
  }
</figure>
