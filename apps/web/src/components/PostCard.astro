---
import PostCardContent from '@/components/PostCardContent.astro'
import SpotlightCard from '@/components/SpotlightCard.astro'
import { formatDate } from '@/lib/date'
import { getPostPath } from '@/lib/routes'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  post: CollectionEntry<'posts'>
  large?: boolean
  spotlight?: boolean
}

const { post, large = false, spotlight = false } = Astro.props
const { publishedAt } = post.data
const formattedDate = formatDate(publishedAt)
const postPath = getPostPath(post)
---

{
  spotlight ? (
    <SpotlightCard as="a" href={postPath} class="block p-8">
      <PostCardContent post={post} large={large} formattedDate={formattedDate} />
    </SpotlightCard>
  ) : (
    <a href={postPath} class="card-hover block">
      <PostCardContent post={post} large={large} formattedDate={formattedDate} />
    </a>
  )
}
