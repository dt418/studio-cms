---
import { SITE } from '@/lib/site'

export interface Props {
  title: string
  description?: string
  image?: string
  canonicalUrl?: string
  publishedTime?: string
  modifiedTime?: string
  author?: string
  type?: 'website' | 'article'
  noindex?: boolean
  jsonLd?: Record<string, unknown>
}

const {
  title,
  description = SITE.description,
  image,
  canonicalUrl,
  publishedTime,
  modifiedTime,
  author = SITE.author,
  type = 'website',
  noindex = false,
  jsonLd,
} = Astro.props

const siteUrl = Astro.site?.origin ?? ''
const defaultImage = `${siteUrl}/og-image.png`
const ogImageUrl = image ? new URL(image, siteUrl || Astro.url.origin).href : defaultImage
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl || Astro.url.origin).href
const twitterCreator = SITE.social.twitter.startsWith('@')
  ? SITE.social.twitter
  : `@${SITE.social.twitter}`
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonical} />

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content="en_US" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{author && <meta property="article:author" content={author} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:creator" content={twitterCreator} />

{author && <meta name="author" content={author} />}
{jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
