---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'
import TagsList from './Blog/TagsList.astro'
import { formatDate } from '@/lib/date'
import { getOptimizedCoverImage } from '@/lib/cover-images'
import { getPostPath } from '@/lib/routes'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { title, excerpt, coverImage, publishedAt, tags, category } = post.data
const formattedDate = formatDate(publishedAt)
const postPath = getPostPath(post)
const optimizedCoverImage = coverImage ? getOptimizedCoverImage(coverImage) : undefined
---

<article class="card-hover group flex flex-col">
  <a href={postPath} class="flex min-h-11 flex-1 flex-col" aria-label={title}>
    {
      coverImage && (
        <div class="bg-muted -m-6 -mt-6 mb-4 aspect-video overflow-hidden">
          {optimizedCoverImage ? (
            <Image
              src={optimizedCoverImage}
              alt={title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              sizes="(max-width: 768px) calc(100vw - 2rem), 400px"
              width="640"
              height="336"
              layout="constrained"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Image
              src={coverImage}
              alt={title}
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              sizes="(max-width: 768px) calc(100vw - 2rem), 400px"
              width="640"
              height="336"
              layout="constrained"
              loading="lazy"
              decoding="async"
            />
          )}
        </div>
      )
    }
    <div class="mb-3 flex items-center gap-2">
      <span
        class="text-muted-foreground/50 border-border border px-2 py-1 font-mono text-[0.62rem] tracking-[0.22em] uppercase"
        >{category}</span
      >
      <time class="text-muted-foreground/40 font-mono text-[0.68rem] tracking-[0.26em] uppercase">
        {formattedDate}
      </time>
    </div>
    <h2 class="text-foreground mb-2 line-clamp-2 text-lg font-semibold tracking-tight">
      {title}
    </h2>
    <p class="text-muted-foreground/70 mb-4 line-clamp-3 text-sm">
      {excerpt}
    </p>
  </a>
  <TagsList tags={tags} post={post} />
</article>
