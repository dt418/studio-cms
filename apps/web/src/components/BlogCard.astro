---
import type { CollectionEntry } from 'astro:content'
import TagsList from './Blog/TagsList.astro'
import { formatDate } from '@/lib/date'
import { getPostPath } from '@/lib/routes'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { title, excerpt, coverImage, publishedAt, tags, category } = post.data
const formattedDate = formatDate(publishedAt)
const postPath = getPostPath(post)
---

<article class="card-hover group">
  <a href={postPath} class="flex flex-1 flex-col">
    {
      coverImage && (
        <div class="bg-muted -m-6 -mt-6 mb-4 aspect-video overflow-hidden">
          <img
            src={coverImage}
            alt={title}
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            width="1200"
            height="630"
            loading="lazy"
            decoding="async"
          />
        </div>
      )
    }
    <div class="mb-3 flex items-center gap-2">
      <span
        class="text-muted-foreground/50 border-border border px-2 py-1 font-mono text-[0.62rem] tracking-[0.22em] uppercase"
        >{category}</span
      >
      <time class="text-muted-foreground/40 font-mono text-[0.68rem] tracking-[0.26em] uppercase">
        {formattedDate}
      </time>
    </div>
    <h2 class="text-foreground mb-2 line-clamp-2 text-lg font-semibold tracking-tight">
      {title}
    </h2>
    <p class="text-muted-foreground/70 mb-4 line-clamp-3 text-sm">
      {excerpt}
    </p>
    <TagsList tags={tags} />
  </a>
</article>
