---
import type { CollectionEntry } from 'astro:content'
import { Button } from './ui/button'
import { Search as SearchIcon } from 'lucide-react'
import { InputGroupInput, InputGroup, InputGroupAddon } from './ui/input-group'
import { FilterSelect } from './ui/FilterSelect'
import { formatDate } from '@/lib/date'
import { getSlug } from '@/lib/content-graph'
import { getPostPath } from '@/lib/routes'

interface FilterI18n {
  sortNewest: string
  sortOldest: string
  sortTitleAZ: string
  sortTitleZA: string
  sortShortest: string
  sortLongest: string
  searchPlaceholder: string
  allCategories: string
  allTags: string
  sortBy: string
  clearTitle: string
  reset: string
  emptyPrompt: string
  noMatch: string
  enter: string
  minRead: string
  single: string
  plural: string
  found: string
}

interface Props {
  posts: CollectionEntry<'posts'>[]
  categories: string[]
  tags: string[]
  initialCategory?: string
  initialTag?: string
  i18n?: FilterI18n
}

const { posts, categories, tags, initialCategory, initialTag, i18n } = Astro.props

const serializedPosts = posts.map((post) => {
  const data = {
    ...post.data,
    slug: getSlug(post),
    path: getPostPath(post),
    publishedAt: post.data.publishedAt.toISOString(),
    formattedDate: formatDate(post.data.publishedAt),
  }
  return { ...post, data }
})

const serializedJson = JSON.stringify(serializedPosts).replace(/</g, '\\u003c')

const sortbyOptions: { value: string; label: string }[] = [
  { value: 'date-desc', label: i18n?.sortNewest ?? 'Newest first' },
  { value: 'date-asc', label: i18n?.sortOldest ?? 'Oldest first' },
  { value: 'title-asc', label: i18n?.sortTitleAZ ?? 'Title A-Z' },
  { value: 'title-desc', label: i18n?.sortTitleZA ?? 'Title Z-A' },
  { value: 'readingTime-asc', label: i18n?.sortShortest ?? 'Shortest first' },
  { value: 'readingTime-desc', label: i18n?.sortLongest ?? 'Longest first' },
]
---

<div class="space-y-4">
  <form id="filter-form" class="flex flex-wrap gap-3" autocomplete="off">
    <!-- SEARCH -->
    <div class="relative min-w-[200px] flex-1">
      <InputGroup className="input w-full">
        <InputGroupInput
          type="search"
          id="filter-search"
          placeholder={i18n?.searchPlaceholder ?? 'Search posts...'}
        />
        <InputGroupAddon>
          <SearchIcon />
        </InputGroupAddon>
      </InputGroup>
    </div>

    <!-- CATEGORY -->
    <div class="w-full sm:w-auto sm:min-w-40">
      <input type="hidden" id="filter-category" />

      <FilterSelect
        client:load
        name="category"
        options={categories}
        {...initialCategory && { value: initialCategory }}
        placeholder={i18n?.allCategories ?? 'All Categories'}
      />
    </div>

    <!-- TAG -->
    <div class="w-full sm:w-auto sm:min-w-40">
      <input type="hidden" id="filter-tag" />

      <FilterSelect
        client:load
        name="tag"
        options={tags}
        {...initialTag && { value: initialTag }}
        placeholder={i18n?.allTags ?? 'All Tags'}
      />
    </div>

    <!-- SORT -->
    <div class="w-full sm:w-auto sm:min-w-40">
      <input type="hidden" id="filter-sort" />

      <FilterSelect
        client:load
        name="sort"
        options={sortbyOptions}
        placeholder={i18n?.sortBy ?? 'Sort By'}
      />
    </div>

    <!-- RESET -->
    <Button
      id="filter-reset"
      type="button"
      title={i18n?.clearTitle ?? 'Clear search and reset filters'}
      className="w-full rounded-none sm:w-auto sm:min-w-20"
      variant="outline"
    >
      {i18n?.reset ?? 'Reset'}
    </Button>
  </form>

  <div id="filter-results-count" class="text-muted-foreground text-sm"></div>

  <div id="filter-results" class="space-y-0">
    <p class="text-muted-foreground py-8 text-center">
      {i18n?.emptyPrompt ?? 'Type to search or adjust filters...'}
    </p>
  </div>
</div>

<script is:inline type="application/json" id="filter-data" set:html={serializedJson} />
<script
  is:inline
  type="application/json"
  id="filter-i18n"
  set:html={JSON.stringify({
    enter: i18n?.enter ?? 'enter',
    min: i18n?.minRead ?? 'min',
    noMatch: i18n?.noMatch ?? 'No posts match your filters.',
    single: i18n?.single ?? 'post',
    plural: i18n?.plural ?? 'posts',
    found: i18n?.found ?? 'found',
  })}
/>

<script>
  import { initBlogFilter } from '@/lib/blog-filter'

  let initialized = false

  function setupFilterBridge() {
    // Prevent form submission
    const form = document.getElementById('filter-form') as HTMLFormElement | null
    if (form) {
      form.addEventListener('submit', (e) => e.preventDefault())
    }

    // React select change -> trigger filter lại
    window.addEventListener('filter-change', () => {
      initBlogFilter()
    })

    // reset button
    const resetBtn = document.getElementById('filter-reset') as HTMLButtonElement
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        const ids = ['filter-category', 'filter-tag', 'filter-sort']
        ids.forEach((id) => {
          const el = document.getElementById(id) as HTMLInputElement | null
          if (el) el.value = ''
        })

        const search = document.getElementById('filter-search') as HTMLInputElement | null
        if (search) search.value = ''

        window.dispatchEvent(new Event('filter-reset'))
        window.dispatchEvent(new Event('filter-change'))
      })
    }
  }

  function init() {
    if (initialized) return
    initialized = true
    initBlogFilter()
    setupFilterBridge()
  }

  document.addEventListener('astro:page-load', init)
  init()
</script>
