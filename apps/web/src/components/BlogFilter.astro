---
import type { CollectionEntry } from 'astro:content'
import { formatDate } from '@/lib/date'
import { getSlug } from '@/lib/content-graph'
import { getPostPath } from '@/lib/routes'

interface Props {
  posts: CollectionEntry<'posts'>[]
  categories: string[]
  tags: string[]
  initialCategory?: string
  initialTag?: string
}

const { posts, categories, tags, initialCategory, initialTag } = Astro.props

const serializedPosts = posts.map((post) => {
  const data = {
    ...post.data,
    slug: getSlug(post),
    path: getPostPath(post),
    publishedAt: post.data.publishedAt.toISOString(),
    formattedDate: formatDate(post.data.publishedAt),
  }
  return { ...post, data }
})

// Escape `<` so a `</script>` substring inside any field cannot break out of the
// JSON island. JSON.stringify by itself does not escape `<`.
const serializedJson = JSON.stringify(serializedPosts).replace(/</g, '\\u003c')
---

<div class="space-y-4">
  <div class="flex flex-wrap gap-3">
    <div class="relative min-w-[200px] flex-1">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground pointer-events-none absolute top-1/2 left-3 h-4 w-4 -translate-y-1/2"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        type="search"
        id="filter-search"
        placeholder="Search posts..."
        class="input w-full pl-10"
      />
    </div>

    <select
      id="filter-category"
      class="input w-full sm:w-auto sm:min-w-[160px]"
      aria-label="Filter posts by category"
    >
      <option value="">All Categories</option>
      {
        categories.map((cat) => (
          <option value={cat} selected={cat === initialCategory}>
            {cat}
          </option>
        ))
      }
    </select>

    <select
      id="filter-tag"
      class="input w-full sm:w-auto sm:min-w-[120px]"
      aria-label="Filter posts by tag"
    >
      <option value="">All Tags</option>
      {
        tags.map((tag) => (
          <option value={tag} selected={tag === initialTag}>
            {tag}
          </option>
        ))
      }
    </select>

    <select
      id="filter-sort"
      class="input w-full sm:w-auto sm:min-w-[160px]"
      aria-label="Sort posts"
    >
      <option value="date-desc">Newest first</option>
      <option value="date-asc">Oldest first</option>
      <option value="title-asc">Title A-Z</option>
      <option value="title-desc">Title Z-A</option>
      <option value="readingTime-asc">Shortest first</option>
      <option value="readingTime-desc">Longest first</option>
    </select>

    <button
      id="filter-reset"
      type="button"
      class="input px-4 font-mono text-sm tracking-wider whitespace-nowrap uppercase transition-colors hover:bg-white/5"
      title="Clear search and reset filters"
    >
      Reset
    </button>
  </div>

  <div id="filter-results-count" class="text-muted-foreground text-sm"></div>

  <div id="filter-results" class="space-y-0">
    <p class="text-muted-foreground py-8 text-center">Type to search or adjust filters...</p>
  </div>
</div>

<script is:inline type="application/json" id="filter-data" set:html={serializedJson} />

<script>
  import { initBlogFilter } from '@/lib/blog-filter'
  document.addEventListener('astro:page-load', initBlogFilter)
  initBlogFilter()
</script>
