---
import MetricCardContent from '@/components/MetricCardContent.astro'
import SpotlightCard from '@/components/SpotlightCard.astro'

export interface Props {
  label: string
  value: string
  category: string
  description: string
  spotlight?: boolean
}

const { label, value, category, description, spotlight = false } = Astro.props
---

{
  spotlight ? (
    <SpotlightCard as="article" class="p-6">
      <MetricCardContent
        label={label}
        value={value}
        category={category}
        description={description}
      />
    </SpotlightCard>
  ) : (
    <article class="card-hover">
      <MetricCardContent
        label={label}
        value={value}
        category={category}
        description={description}
      />
    </article>
  )
}
