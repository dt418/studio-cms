---
export interface Props {
  tags: Array<{ name: string; count: number }>
  lang: string
  title: string
  linkText: string
}

const { tags, lang, title, linkText } = Astro.props

const delayMap: Record<string, string> = {
  '0': 'animation-delay: 0ms',
  '1': 'animation-delay: 75ms',
  '2': 'animation-delay: 150ms',
  '3': 'animation-delay: 225ms',
  '4': 'animation-delay: 300ms',
  '5': 'animation-delay: 375ms',
  '6': 'animation-delay: 450ms',
  '7': 'animation-delay: 525ms',
  '8': 'animation-delay: 600ms',
}
---

<section class="border-border bg-card/20 border-b">
  <div class="container py-10 lg:py-12">
    <div class="mb-8 flex items-end justify-between gap-3">
      <p class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.28em] uppercase">
        {title}
      </p>
      <a
        href={`/${lang}/blog`}
        class="group text-muted-foreground/70 hover:text-foreground font-mono text-[0.72rem] tracking-[0.26em] uppercase transition-all duration-300"
      >
        <span class="inline-block transition-transform duration-300 group-hover:translate-x-1">
          {linkText}
        </span>
        <span class="ml-1 inline-block transition-transform duration-300 group-hover:translate-x-1">
          →
        </span>
      </a>
    </div>
    <div class="flex flex-wrap gap-2">
      {
        tags.map(({ name, count }, index) => (
          <a
            href={`/${lang}/blog?tag=${encodeURIComponent(name)}`}
            style={delayMap[index.toString()] ?? ''}
            class="animate-fade-in-up border-border text-muted-foreground hover:border-accent-warm hover:text-accent-warm group relative inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs opacity-0 transition-all duration-300 hover:-ml-0.5 hover:bg-white/[0.03]"
          >
            <span class="bg-accent-warm absolute inset-y-0 left-0 w-0.5 rounded-full opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
            <span class="transition-colors duration-300">#{name}</span>
            <span class="text-muted-foreground/40 text-[0.65rem] transition-colors duration-300">
              {count}
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 400ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
