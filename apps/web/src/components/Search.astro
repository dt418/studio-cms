---
import SearchIcon from './icons/SearchIcon.astro'
import ClearIcon from './icons/ClearIcon.astro'
import SearchFilters from './SearchFilters.astro'

interface Props {
  placeholder?: string
}

const { placeholder = 'Search articles...' } = Astro.props
---

<div class="search">
  <div class="search-field">
    <SearchIcon class="search-icon" />
    <input
      type="search"
      id="search-input"
      placeholder={placeholder}
      class="input search-input-el"
      autocomplete="off"
      spellcheck="false"
    />
    <button
      id="search-clear"
      type="button"
      class="search-clear-btn"
      aria-label="Clear search"
      hidden
    >
      <ClearIcon />
    </button>
  </div>

  <SearchFilters />

  <div id="search-status" class="search-status" hidden></div>
  <div id="search-results" class="search-results"></div>
</div>

<style is:global>
  .search {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .search-field {
    position: relative;
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    height: 1rem;
    width: 1rem;
    color: var(--color-muted-foreground);
    pointer-events: none;
  }

  .search-input-el {
    padding-left: 2.5rem;
  }

  .search-clear-btn {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    height: 1rem;
    width: 1rem;
    color: var(--color-muted-foreground);
    cursor: pointer;
    transition: color 150ms;
    background: none;
    border: none;
    padding: 0;
  }

  .search-clear-btn:hover {
    color: var(--color-foreground);
  }

  .search-filters {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .search-filter-select {
    width: auto;
    min-width: 140px;
    font-size: 0.875rem;
  }

  .search-status {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
  }

  .search-results {
    display: flex;
    flex-direction: column;
  }

  .search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
  }

  .search-empty p {
    color: var(--color-muted-foreground);
    font-size: 0.875rem;
  }

  .search-result {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
    transition: background-color 200ms;
    border-radius: var(--radius-md);
    margin: 0 -1rem;
  }

  .search-result:first-child {
    padding-top: 0;
  }

  .search-result:last-child {
    border-bottom: none;
    padding-bottom: 0;
    margin-bottom: 0;
  }

  .search-result:hover {
    background-color: var(--color-accent);
  }

  .search-result--with-image {
    grid-template-columns: 80px 1fr auto;
  }

  .search-result__image {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-md);
    overflow: hidden;
    flex-shrink: 0;
    background-color: var(--color-secondary);
  }

  .search-result__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .search-result__body {
    min-width: 0;
  }

  .search-result__link {
    display: block;
  }

  .search-result__title {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: -0.025em;
    color: var(--color-foreground);
    opacity: 0.9;
    margin-bottom: 0.375rem;
    transition: opacity 150ms;
  }

  .search-result:hover .search-result__title {
    opacity: 1;
  }

  .search-result__excerpt {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted-foreground);
    opacity: 0.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .search-result__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }

  .search-result__aside {
    display: flex;
    flex-direction: column;
    align-items: end;
    gap: 0.25rem;
  }

  .search-result__enter {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted-foreground);
    opacity: 0.4;
    transition: opacity 150ms;
  }

  .search-result:hover .search-result__enter {
    opacity: 0.7;
  }

  .search-result__enter svg {
    transition: transform 150ms;
  }

  .search-result:hover .search-result__enter svg {
    transform: translateX(0.125rem);
  }

  .search-result__score {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-muted-foreground);
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  .search-result__date {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-muted-foreground);
    opacity: 0.3;
    font-variant-numeric: tabular-nums;
  }

  .search-badge {
    display: inline-flex;
    align-items: center;
    border-radius: var(--radius-sm);
    background-color: var(--color-secondary);
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-muted-foreground);
    line-height: 1;
  }

  .search-badge--category {
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }

  .search-badge--tag {
    opacity: 0.5;
  }

  .search-badge--overflow {
    opacity: 0.5;
  }

  mark {
    background-color: color-mix(in srgb, var(--color-primary) 20%, transparent);
    color: var(--color-foreground);
    border-radius: var(--radius-sm);
    padding: 0 0.125rem;
  }
</style>

<script>
  import { initSearch, loadFuse } from '@/lib/search'

  const startSearch = () => {
    void loadFuse()
    initSearch()
  }

  document.addEventListener('astro:page-load', startSearch)

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startSearch, { once: true })
  } else {
    startSearch()
  }
</script>
