---
export interface Props {
  title: string
  description?: string
  link?: string
  linkText?: string
}

const { title, description, link, linkText } = Astro.props
---

<section class="border-border bg-card/20 border-b">
  <div class="container py-10 lg:py-12">
    <div
      class="border-border flex flex-col gap-4 border-b pb-6 lg:flex-row lg:items-end lg:justify-between"
    >
      <div class="max-w-2xl">
        <p class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.28em] uppercase">
          {title}
        </p>
        <slot name="header" />
      </div>
      {
        link && (
          <a
            href={link}
            class="text-muted-foreground/50 hover:text-foreground font-mono text-[0.72rem] tracking-[0.26em] uppercase transition-colors"
          >
            {linkText}
          </a>
        )
      }
    </div>
    {
      description && (
        <p class="text-muted-foreground/60 mb-6 max-w-xl text-sm leading-6 sm:text-base sm:leading-7">
          {description}
        </p>
      )
    }
    <slot />
  </div>
</section>
