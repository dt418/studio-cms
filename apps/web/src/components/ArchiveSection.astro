---
import type { Post } from '@/lib/content-graph'
import { getTranslations } from '@/lib/i18n'
import { formatDate } from '@/lib/date'
import { getPostPath } from '@/lib/routes'

interface Props {
  posts: Post[]
  lang?: 'vi' | 'en'
}

const { posts, lang = 'vi' } = Astro.props
const i18n = getTranslations(lang)
const labels = i18n.archive

const archivePath = lang === 'en' ? '/en/blog' : '/vi/blog'
---

<section class="border-border border-b">
  <div class="container py-14 lg:py-24">
    <div class="flex flex-col gap-4 pb-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.28em] uppercase">
          {labels.browse}
        </p>
        <h2 class="mt-4 max-w-2xl text-2xl font-semibold tracking-tight lg:text-3xl">
          {labels.allPosts}
        </h2>
        <p class="text-muted-foreground/70 mt-4 max-w-2xl text-base leading-7 sm:text-lg">
          {labels.fullArchive}
        </p>
      </div>
      <a
        href={archivePath}
        class="text-muted-foreground/50 hover:text-foreground font-mono text-[0.72rem] tracking-[0.26em] uppercase transition-colors"
      >
        {labels.openFullArchive} →
      </a>
    </div>
    {
      posts.length === 0 ? (
        <p class="text-muted-foreground/60 mt-8 text-sm">{labels.noArchivedPosts}</p>
      ) : (
        <ul class="divide-border border-border mt-8 divide-y border-y">
          {posts.map((post) => (
            <li>
              <a
                href={getPostPath(post)}
                class="-mx-4 grid grid-cols-[120px_1fr_auto] items-baseline gap-4 rounded-sm px-4 py-5 transition-colors hover:bg-white/2 sm:gap-6"
              >
                <time
                  datetime={post.data.publishedAt.toISOString()}
                  class="text-muted-foreground/50 font-mono text-[0.7rem] tracking-[0.22em] uppercase tabular-nums"
                >
                  {formatDate(post.data.publishedAt)}
                </time>
                <span class="text-foreground/90 line-clamp-1 text-sm font-medium">
                  {post.data.title}
                </span>
                <span class="text-muted-foreground/40 font-mono text-[0.62rem] tracking-[0.22em] uppercase">
                  {post.data.category}
                </span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</section>
