<button
  id="theme-toggle"
  type="button"
  class="hover:bg-accent hover:text-accent-foreground inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors"
  aria-label="Toggle theme"
>
  <svg
    class="theme-light-icon h-4 w-4"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path><path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path><path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg
    class="theme-dark-icon hidden h-4 w-4"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script is:inline>
  const STORAGE_KEY = 'theme-config'
  const DARK_CLASS = 'dark'
  const root = document.documentElement

  function getConfig() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY)
      return raw ? JSON.parse(raw) : null
    } catch {
      console.error('Failed to load theme config')
      return null
    }
  }

  function applyTheme(config) {
    const root = document.documentElement
    const DARK_CLASS = 'dark'

    const isDark = config?.theme ? config.theme === 'dark' : root.classList.contains(DARK_CLASS)

    root.classList.toggle(DARK_CLASS, isDark)

    const sunIcon = document.querySelector('.theme-light-icon')
    const moonIcon = document.querySelector('.theme-dark-icon')

    if (sunIcon && moonIcon) {
      sunIcon.classList.toggle('hidden', !isDark)
      moonIcon.classList.toggle('hidden', isDark)
    }
  }

  function handleClick() {
    const config = getConfig() || { theme: 'dark', primary: { l: 0.205, c: 0, h: 0 } }
    config.theme = root.classList.contains(DARK_CLASS) ? 'light' : 'dark'
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(config))
    } catch {
      console.error('Failed to save theme config')
      return null
    }
    applyTheme(config)
  }

  function init() {
    applyTheme(getConfig())
  }

  init()

  document.addEventListener('astro:after-swap', function () {
    init()
    const btn = document.getElementById('theme-toggle')
    if (btn) {
      const clone = btn.cloneNode(true)
      btn.parentNode.replaceChild(clone, btn)
      clone.addEventListener('click', handleClick)
    }
  })

  const btn = document.getElementById('theme-toggle')
  if (btn) btn.addEventListener('click', handleClick)
</script>
