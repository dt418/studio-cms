---
import { getSlug } from '@/lib/content-graph'
import { formatDate } from '@/lib/date'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  post: CollectionEntry<'posts'>
  large?: boolean
}

const { post, large = false } = Astro.props
const { title, excerpt, category, publishedAt, tags } = post.data
const formattedDate = formatDate(publishedAt)
const resolvedSlug = getSlug(post)
---

<a href={`/blog/${resolvedSlug}`} class="card-hover block">
  <div class="flex items-center gap-3 mb-4">
    <span class="font-mono text-[0.68rem] tracking-[0.26em] uppercase text-muted-foreground/50">
      {category}
    </span>
    <span class="text-muted-foreground/30">/</span>
    <time class="font-mono text-[0.68rem] tracking-[0.26em] uppercase text-muted-foreground/40">
      {formattedDate}
    </time>
  </div>
  <h3
    class={large
      ? 'text-xl lg:text-2xl font-semibold tracking-tight mb-4 text-foreground'
      : 'text-lg font-semibold tracking-tight mb-2 text-foreground'}
  >
    {title}
  </h3>
  <p
    class={large
      ? 'text-sm leading-7 text-muted-foreground/70 mb-6'
      : 'text-sm leading-6 text-muted-foreground/60 mb-4'}
  >
    {excerpt}
  </p>
  {
    large && (
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.slice(0, 3).map((tag) => (
          <span class="font-mono text-[0.62rem] tracking-[0.22em] uppercase text-muted-foreground/50 border border-border px-2 py-1">
            {tag}
          </span>
        ))}
      </div>
    )
  }
  <span class="font-mono text-[0.62rem] tracking-[0.24em] uppercase text-muted-foreground/50">
    Read more →
  </span>
</a>
