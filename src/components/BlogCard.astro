---
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { title, excerpt, coverImage, publishedAt, tags, category } = post.data
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<article class="card group flex flex-col overflow-hidden animate-on-scroll" transition:name={`card-${post.data.slug}`}>
  <a href={`/blog/${post.data.slug}`} class="flex flex-col flex-1">
    {coverImage && (
      <div class="aspect-video overflow-hidden bg-muted" transition:name={`card-img-${post.data.slug}`}>
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )}
    <div class="card-header flex-1">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors border-transparent bg-secondary text-secondary-foreground">{category}</span>
        <time class="text-xs text-muted-foreground">{formattedDate}</time>
      </div>
      <h2 class="card-title group-hover:text-muted-foreground transition-colors line-clamp-2" transition:name={`card-title-${post.data.slug}`}>
        {title}
      </h2>
      <p class="text-sm text-muted-foreground mt-2 line-clamp-3">
        {excerpt}
      </p>
    </div>
    <div class="card-footer pt-0">
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors border-transparent bg-secondary text-secondary-foreground">
            {tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors border-transparent bg-secondary text-secondary-foreground">
            +{tags.length - 3}
          </span>
        )}
      </div>
    </div>
  </a>
</article>
