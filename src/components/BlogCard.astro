---
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props
const { title, excerpt, coverImage, publishedAt, tags, category } = post.data
const formattedDate = publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<article class="card-hover group">
  <a href={`/blog/${post.data.slug}`} class="flex flex-col flex-1">
    {
      coverImage && (
        <div class="aspect-video overflow-hidden bg-muted -m-6 -mt-6 mb-4">
          <img
            src={coverImage}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      )
    }
    <div class="flex items-center gap-2 mb-3">
      <span
        class="font-mono text-[0.62rem] tracking-[0.22em] uppercase text-muted-foreground/50 border border-border px-2 py-1"
        >{category}</span
      >
      <time class="font-mono text-[0.68rem] tracking-[0.26em] uppercase text-muted-foreground/40">
        {formattedDate}
      </time>
    </div>
    <h2 class="text-lg font-semibold tracking-tight mb-2 text-foreground line-clamp-2">
      {title}
    </h2>
    <p class="text-sm text-muted-foreground/70 mb-4 line-clamp-3">
      {excerpt}
    </p>
    <div class="flex flex-wrap gap-2">
      {
        tags
          .slice(0, 3)
          .map((tag) => (
            <span class="font-mono text-[0.62rem] tracking-[0.22em] uppercase text-muted-foreground/50 border border-border px-2 py-1">
              {tag}
            </span>
          ))
      }
      {
        tags.length > 3 && (
          <span class="font-mono text-[0.62rem] tracking-[0.22em] uppercase text-muted-foreground/50 border border-border px-2 py-1">
            +{tags.length - 3}
          </span>
        )
      }
    </div>
  </a>
</article>