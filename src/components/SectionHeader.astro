---
export interface Props {
  title: string
  description?: string
  link?: string
  linkText?: string
}

const { title, description, link, linkText } = Astro.props
---

<section class="border-b border-border bg-card/20">
  <div class="container py-10 lg:py-12">
    <div class="flex flex-col gap-4 border-b border-border pb-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50">
          {title}
        </p>
        <slot name="header" />
      </div>
      {link && (
        <a href={link} class="font-mono text-[0.72rem] tracking-[0.26em] uppercase text-muted-foreground/50 hover:text-foreground transition-colors">
          {linkText}
        </a>
      )}
    </div>
    {description && (
      <p class="max-w-xl text-sm leading-6 text-muted-foreground/60 sm:text-base sm:leading-7 mb-6">
        {description}
      </p>
    )}
    <slot />
  </div>
</section>