---
export interface Props {
  posts: number
  categories: number
  allTags: number
}

const { posts, categories, allTags } = Astro.props
---

<section class="border-b border-border bg-[#050505]">
  <div class="container py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] gap-10">
      <!-- Left Column -->
      <div class="flex flex-col justify-between gap-6">
        <div class="max-w-4xl">
          <p
            class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50 mb-6"
          >
            For developers shipping modern web products
          </p>
          <h1
            class="text-[clamp(2.5rem,12vw,7rem)] leading-[0.84] font-semibold tracking-[-0.09em] uppercase mb-6"
          >
            <span class="block">Danh</span>
            <span class="block text-muted-foreground">Thanh</span>
          </h1>
          <p
            class="max-w-xl text-[0.98rem] leading-7 text-muted-foreground/70 sm:text-lg sm:leading-8"
          >
            Software engineer sharing practical insights on designing, developing, launching, and
            growing modern web products.
          </p>
        </div>
        <div class="max-w-xl space-y-4">
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href="/blog" class="btn btn-primary btn-lg"> Read the blog </a>
            <a href="/rss.xml" class="btn btn-outline btn-lg"> RSS Feed </a>
          </div>
          <div
            class="hidden flex-wrap items-center gap-3 text-[0.72rem] tracking-[0.26em] uppercase sm:flex"
          >
            <span class="rounded-full border border-border px-3 py-1.5">
              {posts} posts
            </span>
            <span class="rounded-full border border-border px-3 py-1.5">
              {categories} topics
            </span>
            <span class="rounded-full border border-border px-3 py-1.5">
              {allTags} tags
            </span>
          </div>
        </div>
      </div>
      <!-- Right Column - Terminal Panel -->
      <slot name="terminal" />
    </div>
  </div>
</section>
