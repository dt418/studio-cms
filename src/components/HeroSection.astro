---
import StatsBadge from './StatsBadge.astro'
import CTAButtons from './CTAButtons.astro'

export interface Props {
  posts: number
  categories: number
  allTags: number
}

const { posts, categories, allTags } = Astro.props
---

<section class="border-border bg-background border-b">
  <div class="container py-12 lg:py-16">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
      <!-- Left Column -->
      <div class="flex flex-col justify-between gap-6">
        <div class="max-w-4xl">
          <p
            class="text-muted-foreground/50 mb-6 font-mono text-[0.62rem] tracking-[0.28em] uppercase"
          >
            For developers shipping modern web products
          </p>
          <h1
            class="mb-6 text-[clamp(2.5rem,12vw,7rem)] leading-[0.84] font-semibold tracking-[-0.09em] uppercase"
          >
            <span class="block">Danh</span>
            <span class="text-muted-foreground block">Thanh</span>
          </h1>
          <p
            class="text-muted-foreground/70 max-w-xl text-[0.98rem] leading-7 sm:text-lg sm:leading-8"
          >
            Software engineer sharing practical insights on designing, developing, launching, and
            growing modern web products.
          </p>
        </div>
        <div class="max-w-xl space-y-4">
          <CTAButtons />
          <div
            class="hidden flex-wrap items-center gap-3 text-[0.72rem] tracking-[0.26em] uppercase sm:flex"
          >
            <StatsBadge label="posts" value={posts} />
            <StatsBadge label="topics" value={categories} />
            <StatsBadge label="tags" value={allTags} />
          </div>
        </div>
      </div>
      <!-- Right Column - Terminal Panel -->
      <slot name="terminal" />
    </div>
  </div>
</section>
