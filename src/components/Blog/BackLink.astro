---
interface Props {
  href: string
  text?: string
}

const { href, text = 'Back to Blog' } = Astro.props
---

<a
  href={href}
  class="text-muted-foreground hover:text-foreground mb-4 inline-flex items-center gap-1 text-sm font-medium transition-colors"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-4 w-4"
  >
    <path d="m15 18-6-6 6-6"></path>
  </svg>
  {text}
</a>
