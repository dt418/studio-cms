---
import type { CollectionEntry } from 'astro:content'
import NavigationLink from './NavigationLink.astro'

interface Props {
  prevPost?: CollectionEntry<'posts'>['data']
  nextPost?: CollectionEntry<'posts'>['data']
}

const { prevPost, nextPost } = Astro.props as Props
---

{
  prevPost || nextPost ? (
    <nav class="mt-16 pt-8 border-t border-border" aria-label="Post navigation">
      <div class="grid gap-4 md:grid-cols-2">
        {prevPost ? <NavigationLink post={prevPost} direction="prev" /> : <div />}
        {nextPost ? <NavigationLink post={nextPost} direction="next" /> : <div />}
      </div>
    </nav>
  ) : null
}
