---
import { getAuthorInitials } from '@/lib/utils'

interface Props {
  author: string
}

const { author } = Astro.props
---

<article class="card-hover flex items-center gap-4">
  <div
    class="h-12 w-12 rounded-full bg-primary/10 flex items-center justify-center text-base font-semibold text-primary"
  >
    {getAuthorInitials(author)}
  </div>
  <div>
    <p class="font-medium text-foreground">{author}</p>
    <p class="text-sm text-muted-foreground">Writer & Developer</p>
  </div>
</article>
