---
import Breadcrumb from './Breadcrumb.astro'
import TagsList from './TagsList.astro'
import PostMetadata from './PostMetadata.astro'
import CoverImage from './CoverImage.astro'

interface Props {
  category: string
  title: string
  excerpt: string
  tags: string[]
  publishedAt: string
  readingTime: number
  coverImage?: string
}

const { category, title, excerpt, tags, publishedAt, readingTime, coverImage } = Astro.props
---

<div class="space-y-6">
  <Breadcrumb title={title} />

  <!-- Title -->
  <h1
    class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] text-foreground"
  >
    {title}
  </h1>

  <!-- Excerpt -->
  <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl">
    {excerpt}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    <span
      class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary border border-primary/20"
    >
      {category}
    </span>
    <TagsList tags={tags} />
  </div>

  <PostMetadata publishedAt={publishedAt} readingTime={readingTime} />

  <!-- Divider -->
  <div class="h-px bg-border"></div>
</div>

{coverImage && <CoverImage coverImage={coverImage} title={title} />}
