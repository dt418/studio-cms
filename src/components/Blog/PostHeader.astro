---
interface Props {
  category: string
  title: string
  excerpt: string
  tags: string[]
  publishedAt: string
  readingTime: number
  coverImage?: string
}

const { category, title, excerpt, tags, publishedAt, readingTime, coverImage } = Astro.props
---

<div class="space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-muted-foreground" aria-label="Breadcrumb">
    <a href="/" class="hover:text-foreground transition-colors">Home</a>
    <span class="text-muted-foreground/40">/</span>
    <a href="/blog" class="hover:text-foreground transition-colors">Blog</a>
    <span class="text-muted-foreground/40">/</span>
    <span class="text-foreground truncate max-w-[200px]">{title}</span>
  </nav>

  <!-- Title -->
  <h1
    class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] text-foreground"
  >
    {title}
  </h1>

  <!-- Excerpt -->
  <p class="text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl">
    {excerpt}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    <span
      class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary border border-primary/20"
    >
      {category}
    </span>
    {
      tags.map((tag) => (
        <span class="inline-flex items-center rounded-full border border-border px-3 py-1 text-xs font-medium text-muted-foreground hover:text-foreground transition-colors">
          #{tag}
        </span>
      ))
    }
  </div>

  <!-- Metadata -->
  <div class="flex items-center gap-4 text-sm text-muted-foreground">
    <time datetime={publishedAt}>{publishedAt}</time>
    <span class="text-muted-foreground/40">&middot;</span>
    <span>{readingTime} min read</span>
  </div>

  <!-- Divider -->
  <div class="h-px bg-border"></div>
</div>

{
  coverImage && (
    <div class="mt-8 rounded-xl overflow-hidden border border-border">
      <img src={coverImage} alt={title} class="w-full h-auto object-cover" />
    </div>
  )
}
