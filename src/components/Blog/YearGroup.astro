---
import type { Post } from '@/types/post'
import PostItem from './PostItem.astro'

export interface Props {
  year: number
  posts: Post[]
}

const { year, posts } = Astro.props
---

<section class="mb-12 last:mb-0">
  <h2
    class="text-muted-foreground/40 mb-6 border-b border-white/5 pb-3 font-mono text-xs font-semibold tracking-wider uppercase"
  >
    {year}
    <span class="text-muted-foreground/30 ml-2">({posts.length})</span>
  </h2>

  <div>
    {posts.map((post) => <PostItem post={post} />)}
  </div>
</section>
