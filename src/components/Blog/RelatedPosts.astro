---
import BlogCard from '@/components/BlogCard.astro'
import type { CollectionEntry } from 'astro:content'

interface Props {
  relatedPosts: CollectionEntry<'posts'>[]
}

const { relatedPosts } = Astro.props
---

{
  relatedPosts.length > 0 && (
    <section class="border-border border-t">
      <div class="container py-16">
        <div class="mb-8 flex items-center justify-between">
          <h2 class="text-foreground text-2xl font-bold tracking-tight">Related Posts</h2>
          <span class="text-muted-foreground/50 border-border rounded-full border px-3 py-1 font-mono text-xs">
            {relatedPosts.length}
          </span>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <BlogCard post={relatedPost} />
          ))}
        </div>
      </div>
    </section>
  )
}
