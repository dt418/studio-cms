---
import BlogCard from '@/components/BlogCard.astro'
import type { CollectionEntry } from 'astro:content'

interface Props {
  relatedPosts: CollectionEntry<'posts'>[]
}

const { relatedPosts } = Astro.props
---

{
  relatedPosts.length > 0 && (
    <section class="border-t border-border">
      <div class="container py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold tracking-tight text-foreground">Related Posts</h2>
          <span class="font-mono text-xs text-muted-foreground/50 border border-border px-3 py-1 rounded-full">
            {relatedPosts.length}
          </span>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {relatedPosts.map((relatedPost) => (
            <BlogCard post={relatedPost} />
          ))}
        </div>
      </div>
    </section>
  )
}
