---
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'posts'>['data']
  direction: 'prev' | 'next'
}

const { post, direction } = Astro.props
---

<a
  href={`/blog/${post.slug}`}
  class={`group rounded-xl border border-border p-5 transition-colors hover:bg-accent/50 ${
    direction === 'next' ? 'text-right' : ''
  }`}
  aria-label={`${direction === 'prev' ? 'Previous' : 'Next'} post: ${post.title}`}
>
  <p class="text-xs text-muted-foreground mb-1">
    {direction === 'prev' ? 'Previous Post' : 'Next Post'}
  </p>

  <p
    class="text-sm font-medium text-foreground group-hover:text-primary transition-colors line-clamp-2"
  >
    {direction === 'prev' ? '← ' : ''}
    {post.title}
    {direction === 'next' ? ' →' : ''}
  </p>
</a>
