---
interface Props {
  categories: string[]
  currentCategory?: string
}

const { categories, currentCategory } = Astro.props
---

<div class="mb-8">
  <h2 class="text-sm font-medium text-muted-foreground mb-3">All Categories</h2>
  <div class="flex flex-wrap gap-2">
    {
      categories.map((cat) => (
        <a
          href={`/categories/${cat}`}
          class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors"
          class:list={[
            cat === currentCategory
              ? 'bg-primary text-primary-foreground border-transparent'
              : 'hover:bg-accent hover:text-accent-foreground',
          ]}
        >
          {cat}
        </a>
      ))
    }
  </div>
</div>
