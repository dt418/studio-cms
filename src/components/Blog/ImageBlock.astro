---
interface Props {
  src: string
  alt: string
  caption?: string
}

const { src, alt, caption } = Astro.props
---

<figure class="my-8">
  <div class="border-border overflow-hidden rounded-xl border">
    <img src={src} alt={alt} class="h-auto w-full object-cover" />
  </div>
  {
    caption && (
      <figcaption class="text-muted-foreground mt-3 text-center text-sm italic">
        {caption}
      </figcaption>
    )
  }
</figure>
