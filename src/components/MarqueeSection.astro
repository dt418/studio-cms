---
export interface Props {
  items: string[]
}

const { items } = Astro.props

const duplicatedItems = Array.from({ length: 12 }, () => items).flat()
---

<section class="border-border overflow-hidden border-b">
  <div class="py-4">
    <div class="animate-marquee flex gap-6 whitespace-nowrap">
      {
        duplicatedItems.map((item) => (
          <span class="text-muted-foreground/40 font-mono text-[0.62rem] tracking-[0.24em] uppercase">
            {item}
            <span class="text-muted-foreground/20 ml-6">/</span>
          </span>
        ))
      }
    </div>
  </div>
</section>
