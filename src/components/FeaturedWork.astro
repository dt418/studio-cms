---
import PostCard from '@/components/PostCard.astro'
import type { Post } from '@/lib/cms'

interface Props {
  featuredPost: Post | null
  recentPosts: Post[]
}

const { featuredPost = null, recentPosts } = Astro.props
---

<section class="border-border border-b">
  <div class="container py-14 lg:py-24">
    <div class="mb-10 max-w-3xl">
      <p class="text-muted-foreground/50 font-mono text-[0.62rem] tracking-[0.28em] uppercase">
        Featured
      </p>
      <h2 class="mt-4 max-w-2xl text-2xl font-semibold tracking-tight lg:text-3xl">
        Latest from the blog.
      </h2>
      <p class="text-muted-foreground/70 mt-4 max-w-2xl text-base leading-7 sm:text-lg">
        Recent tutorials, guides, and notes on web development.
      </p>
    </div>
    <div class="grid gap-4 lg:grid-cols-12">
      {
        featuredPost ? (
          <div class="card-hover lg:col-span-7">
            <PostCard post={featuredPost} large />
          </div>
        ) : null
      }
      <div class="grid gap-4 lg:col-span-5">
        {recentPosts.map((recentPost) => <PostCard post={recentPost} />)}
      </div>
    </div>
  </div>
</section>
