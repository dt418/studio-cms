---
import PostCard from '@/components/PostCard.astro'

interface PostData {
  title: string
  excerpt: string
  slug: string
  category: string
  publishedAt: Date
  tags: string[]
}

interface Props {
  featuredPost: PostData | null
  recentPosts: PostData[]
}

const { featuredPost, recentPosts } = Astro.props
---

<section class="border-b border-border">
  <div class="container py-14 lg:py-24">
    <div class="max-w-3xl mb-10">
      <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50">
        Featured
      </p>
      <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mt-4 max-w-2xl">
        Latest from the blog.
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground/70 sm:text-lg">
        Recent tutorials, guides, and notes on web development.
      </p>
    </div>
    <div class="grid gap-4 lg:grid-cols-12">
      {
        featuredPost ? (
          <div class="lg:col-span-7 card-hover">
            <PostCard
              title={featuredPost.title}
              excerpt={featuredPost.excerpt}
              slug={featuredPost.slug}
              category={featuredPost.category}
              publishedAt={featuredPost.publishedAt}
              tags={featuredPost.tags}
              large
            />
          </div>
        ) : null
      }
      <div class="lg:col-span-5 grid gap-4">
        {
          recentPosts.map((post) => (
            <PostCard
              title={post.title}
              excerpt={post.excerpt}
              slug={post.slug}
              category={post.category}
              publishedAt={post.publishedAt}
              tags={post.tags}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>
