---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostCard from '@/components/PostCard.astro'
import { getAllPosts, getAllCategories, getAllTags } from '@/lib/cms'

const posts = await getAllPosts()
const categories = await getAllCategories()
const allTags = await getAllTags()

const featuredPost = posts[0]
const recentPosts = posts.slice(1, 4)
---

<BaseLayout
  title="Danh Thanh - Software Engineer & Developer Blog"
  description="Thoughts, tutorials, and guides on web development, TypeScript, and modern tooling."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'DanhThanh.dev',
    url: 'https://danhthanh.dev',
    description:
      'Thoughts, tutorials, and guides on web development, TypeScript, and modern tooling.',
    author: {
      '@type': 'Person',
      name: 'Danh Thanh',
      url: 'https://danhthanh.dev',
      sameAs: ['https://github.com/dt418', 'https://linkedin.com/in/danhthanh418'],
    },
  }}
>
  <!-- Hero Section -->
  <section class="border-b border-border bg-[#050505]">
    <div class="container py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)] gap-10">
        <div class="flex flex-col justify-between gap-6">
          <div class="max-w-4xl">
            <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50 mb-6">
              For developers shipping modern web products
            </p>
            <h1 class="text-[clamp(2.5rem,12vw,7rem)] leading-[0.84] font-semibold tracking-[-0.09em] uppercase mb-6">
              <span class="block">Danh</span>
              <span class="block text-muted-foreground">Thanh</span>
            </h1>
            <p class="max-w-xl text-[0.98rem] leading-7 text-muted-foreground/70 sm:text-lg sm:leading-8">
              Software engineer sharing practical insights on designing, developing,
              launching, and growing modern web products.
            </p>
          </div>
          <div class="max-w-xl space-y-4">
            <div class="flex flex-col gap-3 sm:flex-row">
              <a href="/blog" class="btn btn-primary btn-lg">
                Read the blog
              </a>
              <a href="/rss.xml" class="btn btn-outline btn-lg">
                RSS Feed
              </a>
            </div>
            <div class="hidden flex-wrap items-center gap-3 text-[0.72rem] tracking-[0.26em] uppercase sm:flex">
              <span class="rounded-full border border-border px-3 py-1.5">
                {posts.length} posts
              </span>
              <span class="rounded-full border border-border px-3 py-1.5">
                {categories.length} topics
              </span>
              <span class="rounded-full border border-border px-3 py-1.5">
                {allTags.length} tags
              </span>
            </div>
          </div>
        </div>
        <div class="hidden lg:flex items-end justify-end">
          <div class="w-full max-w-lg border border-border bg-card/30 p-6">
            <div class="mb-6 border-b border-border pb-4 space-y-3">
              <p class="font-mono text-[0.68rem] tracking-[0.28em] uppercase text-muted-foreground/50">
                who I help
              </p>
              <div class="space-y-2 text-sm text-muted-foreground/80">
                <p>Developers building modern web products who need clear, practical insights.</p>
                <p>Topics: web development, TypeScript, Astro, React, and modern tooling.</p>
              </div>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="space-y-1">
                <p class="font-mono text-[0.66rem] tracking-[0.28em] uppercase text-muted-foreground/40">01</p>
                <p class="text-lg leading-none font-medium">Tutorials</p>
              </div>
              <div class="space-y-1">
                <p class="font-mono text-[0.66rem] tracking-[0.28em] uppercase text-muted-foreground/40">02</p>
                <p class="text-lg leading-none font-medium">Guides</p>
              </div>
              <div class="space-y-1">
                <p class="font-mono text-[0.66rem] tracking-[0.28em] uppercase text-muted-foreground/40">03</p>
                <p class="text-lg leading-none font-medium">Notes</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof Section -->
  <section class="border-b border-border bg-card/20">
    <div class="container py-10 lg:py-12">
      <div class="flex flex-col gap-4 border-b border-border pb-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50">Latest insights</p>
          <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mt-4 max-xl">
            Practical knowledge for modern developers.
          </h2>
        </div>
        <p class="max-w-xl text-sm leading-6 text-muted-foreground/60 sm:text-base sm:leading-7">
          Real tutorials, guides, and notes that help you build better products.
        </p>
      </div>
      <div class="mt-6 grid gap-4 sm:mt-8 sm:gap-5 lg:grid-cols-3">
        {[
          { label: 'Latest', value: posts.length, unit: 'posts', desc: 'Published writing', note: 'Practical tutorials and guides on web development, TypeScript, and modern tooling.' },
          { label: 'Topics', value: categories.length, unit: 'areas', desc: 'Coverage areas', note: 'Deep dives across web development, tooling, architecture, and developer experience.' },
          { label: 'Tags', value: allTags.length, unit: 'tags', desc: 'Keywords', note: 'Tagged and searchable content covering React, Astro, TypeScript, and more.' },
        ].map((item) => (
          <div class="card-hover">
            <p class="font-mono text-[0.68rem] tracking-[0.26em] uppercase text-muted-foreground/40 relative">{item.label}</p>
            <p class="mt-4 text-[1.65rem] leading-none font-semibold tracking-[-0.06em] sm:text-[1.9rem] text-foreground">{item.value} {item.unit}</p>
            <p class="mt-2 font-mono text-[0.7rem] tracking-[0.22em] uppercase text-muted-foreground/60">{item.desc}</p>
            <p class="mt-5 max-w-[30ch] text-sm leading-7 text-muted-foreground/70">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Marquee Strip -->
  <section class="border-b border-border overflow-hidden">
    <div class="py-4">
      <div class="flex gap-6 animate-marquee whitespace-nowrap">
        {[...categories, ...categories].map((cat) => (
          <span class="font-mono text-[0.62rem] tracking-[0.24em] uppercase text-muted-foreground/40">
            {cat}<span class="text-muted-foreground/20 ml-6">/</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="border-b border-border">
    <div class="container py-14 lg:py-24">
      <div class="max-w-3xl mb-10">
        <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50">Featured</p>
        <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mt-4 max-w-2xl">Latest from the blog.</h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground/70 sm:text-lg">
          Recent tutorials, guides, and notes on web development.
        </p>
      </div>
      <div class="grid gap-4 lg:grid-cols-12">
        {featuredPost && (
          <div class="lg:col-span-7 card-hover">
            <PostCard
              title={featuredPost.data.title}
              excerpt={featuredPost.data.excerpt}
              slug={featuredPost.data.slug}
              category={featuredPost.data.category}
              publishedAt={featuredPost.data.publishedAt}
              tags={featuredPost.data.tags}
              large
            />
          </div>
        )}
        <div class="lg:col-span-5 grid gap-4">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              excerpt={post.data.excerpt}
              slug={post.data.slug}
              category={post.data.category}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Archive Section -->
  <section class="border-b border-border">
    <div class="container py-14 lg:py-24">
      <div class="flex flex-col gap-4 pb-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="font-mono text-[0.62rem] tracking-[0.28em] uppercase text-muted-foreground/50">Browse</p>
          <h2 class="text-2xl lg:text-3xl font-semibold tracking-tight mt-4 max-w-2xl">All posts and writing.</h2>
          <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground/70 sm:text-lg">
            The full archive of tutorials, guides, and notes.
          </p>
        </div>
        <a href="/blog" class="font-mono text-[0.72rem] tracking-[0.26em] uppercase text-muted-foreground/50 hover:text-foreground transition-colors">
          Open full archive →
        </a>
      </div>
      <div class="mt-8 grid gap-8 sm:mt-10 lg:grid-cols-12">
        {featuredPost && (
          <div class="lg:col-span-7 card-hover">
            <PostCard
              title={featuredPost.data.title}
              excerpt={featuredPost.data.excerpt}
              slug={featuredPost.data.slug}
              category={featuredPost.data.category}
              publishedAt={featuredPost.data.publishedAt}
              tags={featuredPost.data.tags}
              large
            />
          </div>
        )}
        <div class="lg:col-span-5 space-y-4">
          {recentPosts.map((post) => (
            <PostCard
              title={post.data.title}
              excerpt={post.data.excerpt}
              slug={post.data.slug}
              category={post.data.category}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>