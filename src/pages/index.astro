---
import BaseLayout from '../layouts/BaseLayout.astro'
import BlogCard from '../components/BlogCard.astro'
import Search from '../components/Search.astro'
import { getAllPosts, getAllCategories } from '../lib/cms'
import type { SearchablePost } from '../lib/search'

const posts = await getAllPosts()
const categories = await getAllCategories()
const searchPosts: SearchablePost[] = posts.map((post) => ({
  title: post.data.title,
  excerpt: post.data.excerpt,
  tags: post.data.tags,
  slug: post.data.slug,
  category: post.data.category,
}))

const featuredPost = posts[0]
const remainingPosts = posts.slice(1)
---

<BaseLayout title="DanhThanh.dev" description="Thoughts, tutorials, and guides on web development, TypeScript, and modern tooling.">
  <!-- Hero Section -->
  <section class="border-b border-border">
    <div class="container py-16 lg:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium bg-primary/5 text-primary mb-6 animate-on-scroll">
          <span class="mr-2">✨</span> Welcome to my blog
        </div>
        <h1 class="text-4xl font-bold tracking-tight lg:text-6xl mb-6 leading-tight animate-on-scroll">
          Practical insights for<br class="hidden sm:block" />
          <span class="text-muted-foreground">modern developers</span>
        </h1>
        <p class="text-lg text-muted-foreground mb-8 max-w-2xl mx-auto animate-on-scroll">
          Learn how to design, develop, launch, and grow digital products through practical knowledge and proven frameworks.
        </p>
        <div class="max-w-md mx-auto animate-on-scroll">
          <Search posts={searchPosts} />
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="container py-16 animate-on-scroll">
      <div class="max-w-4xl mx-auto">
        <a href={`/blog/${featuredPost.data.slug}`} class="group block">
          <div class="card overflow-hidden">
            {featuredPost.data.coverImage && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={featuredPost.data.coverImage}
                  alt={featuredPost.data.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-8 lg:p-12">
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center rounded-full border px-3 py-1 text-xs font-semibold transition-colors border-transparent bg-primary text-primary-foreground">
                  {featuredPost.data.category}
                </span>
                <time class="text-sm text-muted-foreground">
                  {featuredPost.data.publishedAt.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })}
                </time>
              </div>
              <h2 class="text-2xl lg:text-3xl font-bold tracking-tight mb-4 group-hover:text-muted-foreground transition-colors">
                {featuredPost.data.title}
              </h2>
              <p class="text-muted-foreground text-lg leading-relaxed">
                {featuredPost.data.excerpt}
              </p>
              <div class="mt-6">
                <span class="inline-flex items-center text-sm font-medium text-primary group-hover:underline">
                  Read more
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1">
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- Categories -->
  <section class="border-t border-border">
    <div class="container py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold tracking-tight">Categories</h2>
        <a href="/blog" class="inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
          View all
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 h-4 w-4">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="flex flex-wrap gap-2">
        {categories.map((cat) => (
          <a
            href={`/categories/${cat}`}
            class="inline-flex items-center rounded-full border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  <section class="border-t border-border">
    <div class="container py-16">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold tracking-tight mb-1">Latest Posts</h2>
          <p class="text-muted-foreground">
            {posts.length} {posts.length === 1 ? 'post' : 'posts'} published
          </p>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {remainingPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>

      {remainingPosts.length === 0 && (
        <div class="text-center py-16 border border-dashed border-border rounded-lg animate-on-scroll">
          <p class="text-muted-foreground">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="border-t border-border bg-muted/30 animate-on-scroll">
    <div class="container py-16 lg:py-20">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold tracking-tight mb-4">
          Enjoyed the content?
        </h2>
        <p class="text-muted-foreground mb-8">
          Follow along for more tutorials, guides, and insights on modern web development.
        </p>
        <div class="flex items-center justify-center gap-4">
          <a href="/blog" class="btn btn-primary btn-lg">
            Browse all posts
          </a>
          <a href="/rss.xml" class="btn btn-outline btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4">
              <path d="M4 11a9 9 0 0 1 9 9" />
              <path d="M4 4a16 16 0 0 1 16 16" />
              <circle cx="5" cy="19" r="1" />
            </svg>
            RSS Feed
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
