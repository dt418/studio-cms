---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogFilter from '@/components/BlogFilter.astro'
import BlogCard from '@/components/BlogCard.astro'
import BackLink from '@/components/Blog/BackLink.astro'
import CategoryCloud from '@/components/Blog/CategoryCloud.astro'
import { getPostsByCategory, getAllCategories, getAllTags } from '@/lib/cms'

const rawCategory = Astro.params.category ?? ''
const category = (() => {
  try {
    return decodeURIComponent(rawCategory)
  } catch {
    return rawCategory
  }
})()
const posts = await getPostsByCategory(category)
const allCategories = await getAllCategories()
const allTags = await getAllTags()
---

<BaseLayout title={`Posts in: ${category}`} description={`All posts in category ${category}`}>
  <section class="container py-16">
    <div class="mb-12">
      <BackLink href="/blog" />
      <h1 class="text-4xl font-bold tracking-tight mb-2">Category: {category}</h1>
      <p class="text-lg text-muted-foreground">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'} in "{category}"
      </p>
    </div>

    <CategoryCloud categories={allCategories} currentCategory={category} />

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="mt-12">
      <h2 class="text-sm font-medium text-muted-foreground mb-4">Search & Filter</h2>
      <BlogFilter
        posts={posts}
        categories={allCategories}
        tags={allTags}
        initialCategory={category}
      />
    </div>
  </section>
</BaseLayout>
