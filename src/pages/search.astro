---
import BaseLayout from '../layouts/BaseLayout.astro'
import SearchComponent from '../components/Search.astro'
import BlogHeader from '@/components/Blog/BlogHeader.astro'
---

<BaseLayout
  title="Search - Danh Thanh"
  description="Search through blog articles, tutorials, and guides."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Search',
    description: 'Search through blog articles, tutorials, and guides.',
    url: new URL('/search', Astro.site).href,
  }}
>
  <BlogHeader
    title="Search"
    description="Find articles, tutorials, and technical notes."
    badge="Search"
  />

  <section class="container py-10">
    <div class="max-w-3xl">
      <SearchComponent placeholder="Search articles, tags, or topics..." />
    </div>
  </section>
</BaseLayout>
