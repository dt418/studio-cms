---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogFilter from '@/components/BlogFilter.astro'
import BlogCard from '@/components/BlogCard.astro'
import BackLink from '@/components/Blog/BackLink.astro'
import TagCloud from '@/components/Blog/TagCloud.astro'
import { getPostsByTag, getAllTags, getAllCategories } from '@/lib/cms'

export const prerender = true

export async function getStaticPaths() {
  const tags = await getAllTags()

  return tags.map((tag) => ({
    params: { tag },
    props: { tag },
  }))
}

const rawTag = Astro.params.tag ?? ''
const tag =
  Astro.props.tag ??
  (() => {
    try {
      return decodeURIComponent(rawTag)
    } catch {
      return rawTag
    }
  })()
const posts = await getPostsByTag(tag)
const allTags = await getAllTags()
const allCategories = await getAllCategories()
---

<BaseLayout title={`Posts tagged: ${tag}`} description={`All posts tagged with ${tag}`}>
  <section class="container py-16">
    <div class="mb-12">
      <BackLink href="/blog" />
      <h1 class="mb-2 text-4xl font-bold tracking-tight">Tag: {tag}</h1>
      <p class="text-muted-foreground text-lg">
        {posts.length}
        {posts.length === 1 ? 'post' : 'posts'} tagged with "{tag}"
      </p>
    </div>

    <TagCloud tags={allTags} currentTag={tag} />

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="mt-12">
      <h2 class="text-muted-foreground mb-4 text-sm font-medium">Search & Filter</h2>
      <BlogFilter posts={posts} categories={allCategories} tags={allTags} initialTag={tag} />
    </div>
  </section>
</BaseLayout>
