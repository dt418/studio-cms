---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostMetaCard from '@/components/Blog/PostMetaCard.astro'
import TableOfContents from '@/components/Blog/TableOfContents.astro'
import PostHero from '@/components/Blog/PostHero.astro'
import ArticleContent from '@/components/Blog/ArticleContent.astro'
import RelatedPosts from '@/components/Blog/RelatedPosts.astro'
import { getPostBySlug, getAllPosts } from '@/lib/cms'
import { readingTime } from '@/lib/reading-time'
import { render } from 'astro:content'
import { SITE } from '@/lib/site'
import { getImageUrl, getAdjacentPosts } from '@/lib/utils'
import { formatDate } from '@/lib/date'

// ============================================================================
// Data Fetching
// ============================================================================

const siteUrl = Astro.site?.origin ?? ''
const slug = Astro.params.slug

if (!slug) {
  return new Response('Slug required', { status: 400, statusText: 'Bad Request' })
}

const post = await getPostBySlug(slug)

if (!post) {
  return new Response('Post not found', { status: 404, statusText: 'Not Found' })
}

const { Content, headings } = await render(post)

// ============================================================================
// Post Data
// ============================================================================

const {
  title,
  excerpt,
  coverImage,
  publishedAt,
  updatedAt,
  tags,
  category,
  author = SITE.author,
} = post.data

const formattedDate = formatDate(publishedAt)
const updatedDate = updatedAt ? formatDate(updatedAt) : undefined

// Content metrics
const bodyText = post.body ?? ''
const wordCount = bodyText.trim().split(/\s+/).filter(Boolean).length
const readingTimeMin = readingTime(bodyText)

// ============================================================================
// Navigation & Related Posts
// ============================================================================

const allPosts = await getAllPosts()
const currentIndex = allPosts.findIndex((entry) => entry.data.slug === slug)
const { prev: prevPost, next: nextPost } = getAdjacentPosts(allPosts, currentIndex)

const relatedPosts = allPosts
  .filter((entry) => entry.data.slug !== slug && entry.data.category === category)
  .slice(0, 3)

// ============================================================================
// SEO & Metadata
// ============================================================================

const canonicalUrl = `${siteUrl}/blog/${slug}`
const publishedTime = publishedAt.toISOString()
const modifiedTime = updatedAt?.toISOString() ?? publishedTime

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: excerpt,
  image: getImageUrl(coverImage, siteUrl),
  datePublished: publishedTime,
  dateModified: modifiedTime,
  author: {
    '@type': 'Person',
    name: author,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  keywords: [...tags, category],
} as const
---

<BaseLayout
  title={`${title} | ${SITE.name}`}
  description={excerpt}
  {...coverImage && { image: coverImage }}
  canonicalUrl={canonicalUrl}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  author={author}
  type="article"
  jsonLd={articleJsonLd}
>
  <article class="min-h-screen" transition:name="post-detail">
    <!-- Hero Section -->
    <PostHero
      category={category}
      title={title}
      excerpt={excerpt}
      tags={tags}
      publishedAt={formattedDate}
      readingTime={readingTimeMin}
      {...coverImage && { coverImage }}
    />

    <!-- 3-Column Layout -->
    <div class="container py-8 lg:py-12">
      <div
        class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[200px_1fr_240px] gap-8 lg:gap-12"
      >
        <!-- Left Sidebar: Table of Contents -->
        <aside class="order-2 lg:order-1">
          <TableOfContents headings={headings} />
        </aside>

        <!-- Center: Article Content -->
        <ArticleContent
          tags={tags}
          author={author}
          {...prevPost && { prevPost }}
          {...nextPost && { nextPost }}
        >
          <Content />
        </ArticleContent>

        <!-- Right Sidebar: Post Meta Card -->
        <aside class="order-3 hidden lg:block">
          <PostMetaCard
            author={author}
            publishedAt={formattedDate}
            {...updatedDate && { updatedAt: updatedDate }}
            readingTime={readingTimeMin}
            wordCount={wordCount}
          />
        </aside>
      </div>
    </div>

    <!-- Related Posts -->
    <RelatedPosts relatedPosts={relatedPosts} />
  </article>
</BaseLayout>
