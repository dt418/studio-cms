---
import BaseLayout from '@/layouts/BaseLayout.astro'
import BlogFilter from '@/components/BlogFilter.astro'
import BlogHeader from '@/components/Blog/BlogHeader.astro'
import StatsGrid from '@/components/Blog/StatsGrid.astro'
import { getAllPosts, getAllCategories, getAllTags } from '@/lib/cms'
import { SITE } from '@/lib/site'

export const prerender = true

const posts = await getAllPosts()
const categories = await getAllCategories()
const tags = await getAllTags()

const stats = [
  { value: posts.length, label: 'Published notes' },
  { value: categories.length, label: 'Categories' },
  { value: tags.length, label: 'Tags' },
  { value: new Date().getFullYear(), label: 'Archive snapshot' },
]
---

<BaseLayout
  title="Blog - Danh Thanh"
  description="Build logs, hackathon writeups, and technical notes."
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Blog Archive',
    description: 'Build logs, hackathon writeups, and technical notes.',
    url: new URL('/blog', Astro.site).href,
    isPartOf: {
      '@type': 'WebSite',
      name: SITE.name,
      url: Astro.site?.origin,
    },
  }}
>
  <BlogHeader title="Blog" description="Build logs, hackathon writeups, and technical notes." />

  <section class="container py-10">
    <StatsGrid stats={stats} />
    <BlogFilter posts={posts} categories={categories} tags={tags} />
  </section>
</BaseLayout>
