{
  "name": "danhthanh-dev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "studiocms": "studiocms",
    "migrate": "studiocms migrate",
    "dev": "astro dev",
    "build": "astro build && node scripts/generate-search-index.mjs && pagefind --site dist/client",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,astro}\" --fix",
