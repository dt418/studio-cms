{
  "name": "danhthanh-dev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "studiocms": "studiocms",
    "migrate": "studiocms migrate",
    "dev": "astro dev",
    "og:generate": "node scripts/generate-og-image.mjs",
    "build": "node scripts/generate-og-image.mjs && astro build && node scripts/generate-search-index.mjs && pagefind --site dist/client",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint \"src/**/*.{ts,tsx,astro}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,astro}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json,md}\"",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "commitlint": "commitlint",
    "postinstall": "node scripts/auto-patch-studiocms.mjs && patch-package"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "^3.7.2",
    "@axe-core/playwright": "^4.11.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@iconify-json/heroicons": "^1.2.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "pagefind": "^1.5.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "shadcn": "^4.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@astrojs/internal-helpers": "0.7.5",
    "@astrojs/node": "^9.5.5",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@base-ui/react": "^1.4.1",
    "@effect/platform": "0.94.5",
    "@effect/platform-node": "0.104.1",
    "@iconify-json/simple-icons": "^1.2.79",
    "@libsql/client": "^0.15.15",
    "@studiocms/blog": "^0.3.0",
    "@studiocms/cfetch": "^0.5.1",
    "@studiocms/html": "^0.3.0",
    "@studiocms/markdoc": "^0.3.0",
    "@studiocms/md": "^0.3.0",
    "@studiocms/mdx": "^0.3.0",
    "@studiocms/ui": "^1.2.0",
    "@studiocms/wysiwyg": "^0.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.18.1",
    "astro-expressive-code": "^0.41.7",
    "canvas": "3.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.2",
    "expressive-code-twoslash": "^0.6.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "studiocms": "^0.4.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ],
  "pnpm": {
    "overrides": {
      "@effect/platform": "0.94.5",
      "@effect/platform-node": "0.104.1",
      "vite": ">=6.4.2",
      "canvas": "3.2.3",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "form-data@<2.5.4": ">=2.5.4",
      "fabric@<7.2.0": ">=7.2.0",
      "qs@<6.14.1": ">=6.14.1",
      "astro@<6.1.6": ">=6.1.6",
      "uuid@<14.0.0": ">=14.0.0",
      "@astrojs/node@<10.0.5": ">=10.0.5"
    }
  }
}