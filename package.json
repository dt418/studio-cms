{
  "name": "danhthanh-dev",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "version": "0.0.1",
  "scripts": {
    "astro": "pnpm --filter @danhthanh/web astro",
    "studiocms": "pnpm --filter @danhthanh/cms studiocms",
    "migrate": "pnpm cms:migrate",
    "dev": "pnpm web:dev",
    "preview": "pnpm web:preview",
    "test": "pnpm web:test",
    "test:watch": "pnpm --filter @danhthanh/web test:watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "web:dev": "pnpm --filter @danhthanh/web dev",
    "web:build": "pnpm --filter @danhthanh/web build",
    "web:preview": "pnpm --filter @danhthanh/web preview",
    "web:e2e:server": "pnpm web:build && pnpm --filter @danhthanh/web preview -- --host 127.0.0.1",
    "web:lint": "pnpm --filter @danhthanh/web lint",
    "web:typecheck": "pnpm --filter @danhthanh/web typecheck",
    "web:test": "pnpm --filter @danhthanh/web test",
    "cms:dev": "pnpm --filter @danhthanh/cms dev",
    "cms:build": "pnpm --filter @danhthanh/cms build",
    "cms:preview": "pnpm --filter @danhthanh/cms preview",
    "cms:lint": "pnpm --filter @danhthanh/cms lint",
    "cms:typecheck": "pnpm --filter @danhthanh/cms typecheck",
    "cms:migrate": "pnpm --filter @danhthanh/cms migrate",
    "lint": "pnpm web:lint && pnpm cms:lint",
    "lint:md": "markdownlint \"*.md\" \"docs/**/*.md\" \"skills/**/*.md\" \"prompts/**/*.md\" \"rules/**/*.md\" \"agents/**/*.md\" \"plans/**/*.md\" \"apps/web/src/content/**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"*.md\" \"docs/**/*.md\" \"skills/**/*.md\" \"prompts/**/*.md\" \"rules/**/*.md\" \"agents/**/*.md\" \"plans/**/*.md\" \"apps/web/src/content/**/*.md\"",
    "lint:fix": "pnpm --filter @danhthanh/web lint:fix && pnpm --filter @danhthanh/cms lint:fix",
    "format": "pnpm --filter @danhthanh/web format && pnpm --filter @danhthanh/cms format",
    "format:check": "pnpm --filter @danhthanh/web format:check && pnpm --filter @danhthanh/cms format:check",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm typecheck",
    "build": "pnpm build:turbo",
    "build:turbo": "turbo run build --filter='./apps/*'",
    "dev:turbo": "turbo run dev --filter='./apps/*'",
    "lint:turbo": "turbo run lint --filter='./apps/*'",
    "format:check:turbo": "turbo run format:check --filter='./apps/*'",
    "typecheck:turbo": "turbo run typecheck --filter='./apps/*'",
    "test:turbo": "turbo run test --filter='@danhthanh/web'",
    "typecheck": "pnpm web:typecheck && pnpm cms:typecheck",
    "commitlint": "commitlint",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "lefthook": "^2.1.6",
    "markdownlint-cli": "^0.46.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.5.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ],
  "pnpm": {
    "overrides": {
      "@effect/platform": "0.94.5",
      "@effect/platform-node": "0.104.1",
      "vite": ">=6.4.2",
      "canvas": "3.2.3",
      "tough-cookie@<4.1.3": ">=4.1.3",
      "form-data@<2.5.4": ">=2.5.4",
      "fabric@<7.2.0": ">=7.2.0",
      "qs@<6.14.1": ">=6.14.1",
      "astro@<6.1.6": ">=6.1.6",
      "uuid@<14.0.0": ">=14.0.0",
      "@astrojs/node@<10.0.5": ">=10.0.5"
    }
  }
}
