    "@astrojs/rss": "^4.0.18",
    "@base-ui/react": "^1.4.1",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@libsql/client": "^0.15.15",
    "@studiocms/blog": "^0.3.0",
    "@studiocms/cfetch": "^0.5.1",
    "@studiocms/html": "^0.3.0",
    "@studiocms/markdoc": "^0.3.0",
    "@studiocms/md": "^0.3.0",
    "@studiocms/mdx": "^0.3.0",
    "@studiocms/ui": "^1.2.0",
    "@studiocms/wysiwyg": "^0.3.0",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^5.18.1",
    "astro-expressive-code": "^0.41.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "effect": "^3.21.1",
    "expressive-code-twoslash": "^0.6.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "studiocms": "^0.4.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
