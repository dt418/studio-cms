{
  "name": "studio-cms",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "version": "0.0.1",
  "scripts": {
    "astro": "pnpm --filter web astro",
    "studiocms": "pnpm --filter cms studiocms",
    "migrate": "pnpm turbo run migrate --filter=./apps/*",
    "dev": "pnpm turbo run dev --filter=./apps/*",
    "preview": "pnpm web:preview",
    "test": "pnpm web:test",
    "test:watch": "pnpm --filter web test:watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:preview": "pnpm --filter web preview",
    "web:e2e:server": "pnpm web:build && pnpm --filter web preview -- --host 127.0.0.1",
    "web:lint": "pnpm --filter web lint",
    "web:typecheck": "pnpm --filter web typecheck",
    "web:test": "pnpm --filter web test",
    "cms:dev": "pnpm --filter cms dev",
    "cms:build": "pnpm --filter cms build",
    "cms:preview": "pnpm --filter cms preview",
    "cms:migrate": "pnpm --filter cms migrate",
    "lint": "pnpm web:lint",
    "lint:patterns": "node scripts/lint-patterns.mjs",
    "lint:md": "markdownlint \"*.md\" \"docs/**/*.md\" \"skills/**/*.md\" \"prompts/**/*.md\" \"rules/**/*.md\" \"agents/**/*.md\" \"plans/**/*.md\" \"apps/web/src/content/**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"*.md\" \"docs/**/*.md\" \"skills/**/*.md\" \"prompts/**/*.md\" \"rules/**/*.md\" \"agents/**/*.md\" \"plans/**/*.md\" \"apps/web/src/content/**/*.md\"",
    "lint:fix": "pnpm --filter web lint:fix",
    "format": "pnpm --filter web format",
    "format:check": "pnpm --filter web format:check",
    "check": "pnpm lint:patterns && pnpm lint && pnpm format:check && pnpm test && pnpm typecheck",
    "build": "pnpm turbo run build --filter=./apps/*",
    "lint:turbo": "turbo run lint --filter='web'",
    "format:check:turbo": "turbo run format:check --filter='web'",
    "typecheck:turbo": "turbo run typecheck --filter='web'",
    "test:turbo": "turbo run test --filter='web'",
    "typecheck": "pnpm web:typecheck",
    "commitlint": "commitlint",
    "vault:pull": "npx dotenv-vault@latest pull && node scripts/vault-sync.mjs",
    "vault:push": "node scripts/vault-sync.mjs --reverse && npx dotenv-vault@latest push",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@probelabs/maid": "^0.0.29",
    "@types/node": "^22.19.17",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "lefthook": "^2.1.6",
    "markdownlint-cli": "^0.46.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.5.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "studiocms>astro": "6",
        "@astrojs/node>astro": "6",
        "@inox-tools/runtime-logger>astro": "6",
        "astro-integration-kit>astro": "6",
        "@effect/platform-node>@effect/platform": "0.94.5",
        "@effect/experimental>@effect/platform": "0.94.5",
        "@effect/cli>@effect/platform": "0.94.5",
        "@studiocms/markdown-remark>@astrojs/internal-helpers": "0.9"
      }
    },
    "overrides": {
      "@effect/platform": "0.94.5",
      "@effect/platform-node": "0.104.1",
      "@effect/experimental": "0.59.0",
      "@effect/sql": "0.50.0",
      "@effect/cluster": "0.57.0",
      "@effect/rpc": "0.74.0"
    }
  },
  "workspaces": [
    ".",
    "apps/*",
    "packages/*",
    "!tender-series"
  ]
}