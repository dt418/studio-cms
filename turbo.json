{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["CMS_*", "SITE_URL", "PUBLIC_SITE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "src/content/**/*",
        "src/styles/**/*",
        "public/**/*",
        "scripts/**/*"
      ],
      "outputs": ["dist/**", "public/og-image.png"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "migrate": {
      "cache": false
    }
  }
}
