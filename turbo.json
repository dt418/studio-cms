{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "CI", "SITE_URL", "CMS_*", "LIBSQL_URL", "LIBSQL_AUTH_TOKEN", "CLOUDFLARE_*"],
  "envMode": "strict",
  "tasks": {
    "build": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "src/content/**/*",
        "astro.config.*",
        "src/styles/**/*",
        "public/**/*",
        "scripts/**/*"
      ],
      "outputs": ["dist/**", "public/og-image.png"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "migrate": {
      "cache": false
    }
  }
}
